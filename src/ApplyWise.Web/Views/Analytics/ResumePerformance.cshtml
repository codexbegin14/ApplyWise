@model ApplyWise.Web.ViewModels.Analytics.ResumePerformanceViewModel
@{ ViewData["Title"] = "Resume Performance"; var activeTab = "resumes"; }
<div class="page-heading"><div><h2>Resume Performance</h2><p>Compare match scores, usage, and interview outcomes by resume version.</p></div></div><partial name="_AnalyticsTabs" model="activeTab" />
@if (Model.Items.Count == 0) { <section class="panel empty-state"><span class="empty-icon">R</span><h3>No resumes to compare</h3><p>Upload and analyze resume versions to unlock performance insights.</p><a class="btn btn-primary" asp-controller="Resumes" asp-action="Create">Upload Resume</a></section> }
else { <div class="resume-performance-grid">@foreach (var item in Model.Items) { <article class="panel resume-performance-card @(item.IsBestPerforming ? "best-performance" : null)"><div class="performance-card-heading"><div><h3>@item.VersionName</h3><p>@item.AnalysisCount saved analysis result@(item.AnalysisCount == 1 ? string.Empty : "s")</p></div>@if (item.IsBestPerforming) { <span class="recommended-label">Best performing</span> } else if (item.IsMostUsed) { <span class="recommended-label neutral-label">Most used</span> }</div><div class="performance-score"><strong>@item.AverageMatchScore.ToString("0.#")%</strong><span>average match</span></div><dl class="performance-stats"><div><dt>Applications used</dt><dd>@item.ApplicationsUsed</dd></div><div><dt>Interviews received</dt><dd>@item.InterviewsReceived</dd></div><div><dt>Interview rate</dt><dd>@item.InterviewRate.ToString("0.#")%</dd></div><div><dt>Last analyzed</dt><dd>@(item.LastAnalyzed?.ToLocalTime().ToString("MMM d, yyyy") ?? "Never")</dd></div></dl></article> }</div> }
