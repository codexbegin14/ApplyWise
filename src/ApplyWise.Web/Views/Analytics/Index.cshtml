@model ApplyWise.Web.ViewModels.Analytics.AnalyticsIndexViewModel
@{ ViewData["Title"] = "Analytics"; var activeTab = "overview"; var overview = Model.Overview; var funnelMax = Math.Max(Math.Max(Math.Max(overview.Funnel.Applied, overview.Funnel.Pending), Math.Max(overview.Funnel.Interview, overview.Funnel.Offered)), Math.Max(Math.Max(overview.Funnel.Accepted, overview.Funnel.Rejected), Math.Max(overview.Funnel.UserRejected, overview.Funnel.Ignored))); funnelMax = Math.Max(funnelMax, 1); }
<div class="page-heading"><div><h2>Analytics</h2><p>Understand your job search performance and skill gaps.</p></div></div>
<partial name="_AnalyticsTabs" model="activeTab" />
@if (overview.TotalApplications == 0)
{
    <section class="panel empty-state"><span class="empty-icon" aria-hidden="true">A</span><h3>No application data yet</h3><p>Add job applications to start seeing analytics.</p><a class="btn btn-primary" asp-controller="JobApplications" asp-action="Create">Add Application</a></section>
}
else
{
    <section class="metric-grid analytics-metrics"><article class="metric-card"><span>Total Applications</span><strong>@overview.TotalApplications</strong><small>@overview.InterviewCount interview event@(overview.InterviewCount == 1 ? string.Empty : "s")</small></article><article class="metric-card"><span>Interview Rate</span><strong>@overview.InterviewRate.ToString("0.#")%</strong><small>Applications with an interview</small></article><article class="metric-card"><span>Average Match Score</span><strong>@overview.AverageMatchScore.ToString("0.#")%</strong><small>Across saved analyses</small></article><article class="metric-card"><span>Top Missing Skill</span><strong class="metric-text-value">@(Model.TopSkillGaps.FirstOrDefault()?.SkillName ?? "Not enough data")</strong><small>@(Model.TopSkillGaps.FirstOrDefault() is { } top ? $"Missing {top.MissingCount} times" : "Run resume analyses to unlock")</small></article></section>

    <div class="analytics-grid">
        <section class="panel"><div class="panel-header"><div><h3>Application status</h3><p>Where every application currently stands</p></div></div><div class="funnel-list">@foreach (var item in FunnelItems()) { <div><span>@item.Label</span><div><i style="width:@((item.Count * 100d / funnelMax).ToString("0.#"))%"></i></div><strong>@item.Count</strong></div> }</div></section>
        <section class="panel"><div class="panel-header"><div><h3>Applications by Status</h3><p>Current tracker distribution</p></div></div><div class="status-distribution">@foreach (var item in overview.ApplicationsByStatus.Where(item => item.Count > 0)) { <div><span class="badge @StatusClass(item.Status)">@item.Status.GetDisplayName()</span><strong>@item.Count</strong></div> }</div></section>
        @* These empty insight previews were removed from the overview. Detailed analytics remain available from their dedicated pages. *@
        @*
        <section class="panel"><div class="panel-header"><div><h3>Top Skill Gaps</h3><p>Repeated missing skills in analysis history</p></div><a asp-action="SkillGaps">View all</a></div>@if (Model.TopSkillGaps.Count == 0) { <div class="compact-empty"><strong>Run resume analysis on a few applications</strong><span>Skill trends will appear here.</span></div> } else { <div class="insight-list">@foreach (var skill in Model.TopSkillGaps) { <div><span><strong>@skill.SkillName</strong><small>@skill.RelatedJobCount related job@(skill.RelatedJobCount == 1 ? string.Empty : "s")</small></span><span class="priority @PriorityClass(skill.Priority)">@skill.Priority</span><b>@skill.MissingCount×</b></div> }</div> }</section>
        <section class="panel"><div class="panel-header"><div><h3>Resume Performance</h3><p>Interview rate and match coverage</p></div><a asp-action="ResumePerformance">View details</a></div>@if (Model.ResumePerformance.Count == 0) { <div class="compact-empty"><strong>No resume data yet</strong></div> } else { <div class="performance-preview">@foreach (var resume in Model.ResumePerformance.Take(4)) { <div><span><strong>@resume.VersionName</strong><small>@resume.ApplicationsUsed applications · @resume.InterviewsReceived interviews</small></span><span><b>@resume.AverageMatchScore.ToString("0.#")%</b><small>avg match</small></span></div> }</div> }</section>
        <section class="panel analytics-wide"><div class="panel-header"><div><h3>Platform Response</h3><p>Where applications are turning into interviews</p></div><a asp-action="Platforms">View details</a></div>@if (Model.Platforms.Count == 0) { <div class="compact-empty"><strong>No platform data yet</strong></div> } else { <div class="platform-preview">@foreach (var platform in Model.Platforms) { <div class="@(platform.IsBestPlatform ? "best-platform" : null)"><span>@platform.Source.GetDisplayName() @if (platform.IsBestPlatform) { <small>Best response</small> }</span><strong>@platform.ApplicationCount</strong><span>@platform.InterviewCount interviews</span><b>@platform.InterviewRate.ToString("0.#")%</b></div> }</div> }</section>
        *@
    </div>
}
@functions {
    private IEnumerable<(string Label, int Count)> FunnelItems() { yield return ("Applied", Model.Overview.Funnel.Applied); yield return ("Pending", Model.Overview.Funnel.Pending); yield return ("Interview", Model.Overview.Funnel.Interview); yield return ("Offered", Model.Overview.Funnel.Offered); yield return ("Accepted", Model.Overview.Funnel.Accepted); yield return ("Rejected", Model.Overview.Funnel.Rejected); yield return ("User rejected", Model.Overview.Funnel.UserRejected); yield return ("Ignored", Model.Overview.Funnel.Ignored); }
    private static string PriorityClass(string priority) => priority switch { "High" => "priority-high", "Medium" => "priority-medium", _ => "priority-low" };
    private static string StatusClass(ApplicationStatus status) => status switch { ApplicationStatus.Applied or ApplicationStatus.Pending => "status-applied", ApplicationStatus.Interview => "status-shortlisted", ApplicationStatus.Offered or ApplicationStatus.Accepted => "status-offer", ApplicationStatus.Rejected or ApplicationStatus.UserRejected => "status-rejected", ApplicationStatus.Ignored => "status-saved", _ => "status-saved" };
}
