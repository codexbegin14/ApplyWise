@model ApplyWise.Web.ViewModels.Analytics.SkillGapsViewModel
@{ ViewData["Title"] = "Skill Gap Trends"; var activeTab = "skills"; }
<div class="page-heading"><div><h2>Skill Gap Trends</h2><p>See which requirements repeatedly appear missing across your analyses.</p></div></div><partial name="_AnalyticsTabs" model="activeTab" />
<nav class="filter-tabs" aria-label="Skill gap date range"><a class="@(Model.Range == "all" ? "active" : null)" asp-route-range="all">All time</a><a class="@(Model.Range == "30" ? "active" : null)" asp-route-range="30">30 days</a><a class="@(Model.Range == "90" ? "active" : null)" asp-route-range="90">90 days</a><a class="@(Model.Range == "365" ? "active" : null)" asp-route-range="365">1 year</a></nav>
@if (Model.Items.Count == 0) { <section class="panel empty-state"><img class="empty-wiso" src="~/images/wiso.png" alt="Wiso, your skill gap assistant" /><h3>No skill gap data yet</h3><p>Run resume analysis on a few applications to unlock skill gap trends.</p><a class="btn btn-primary" asp-controller="ResumeAnalyzer" asp-action="Index"><svg class="ui-icon"><use href="#i-spark" /></svg>Analyze Resume</a></section> }
else { <section class="panel skill-gap-table-panel"><div class="table-responsive"><table class="table app-table"><thead><tr><th>Skill</th><th>Missing count</th><th>Related jobs</th><th>Priority</th><th>Suggested action</th></tr></thead><tbody>@foreach (var item in Model.Items) { <tr><td><strong>@item.SkillName</strong></td><td>@item.MissingCount</td><td>@item.RelatedJobCount</td><td><span class="priority @PriorityClass(item.Priority)">@item.Priority</span></td><td class="suggested-action">@item.SuggestedAction</td></tr> }</tbody></table></div></section> }
@functions { private static string PriorityClass(string priority) => priority switch { "High" => "priority-high", "Medium" => "priority-medium", _ => "priority-low" }; }
