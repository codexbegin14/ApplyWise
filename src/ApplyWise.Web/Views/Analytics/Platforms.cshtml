@model ApplyWise.Web.ViewModels.Analytics.PlatformAnalyticsViewModel
@{ ViewData["Title"] = "Platform Analytics"; var activeTab = "platforms"; }
<div class="page-heading"><div><h2>Platform Response</h2><p>See where your applications are generating interview opportunities.</p></div></div><partial name="_AnalyticsTabs" model="activeTab" />
@if (Model.Items.Count == 0) { <section class="panel empty-state"><span class="empty-icon">P</span><h3>No platform data yet</h3><p>Add job applications to compare source performance.</p><a class="btn btn-primary" asp-controller="JobApplications" asp-action="Create">Add Application</a></section> }
else { <section class="panel platform-table-panel"><div class="table-responsive"><table class="table app-table"><thead><tr><th>Platform</th><th>Applications</th><th>Interviews</th><th>Interview rate</th><th>Response</th></tr></thead><tbody>@foreach (var item in Model.Items) { <tr class="@(item.IsBestPlatform ? "best-platform-row" : null)"><td><strong>@item.Source.GetDisplayName()</strong>@if (item.IsBestPlatform) { <span class="recommended-inline">Best platform</span> }</td><td>@item.ApplicationCount</td><td>@item.InterviewCount</td><td><strong>@item.InterviewRate.ToString("0.#")%</strong></td><td><div class="response-bar"><i style="width:@item.InterviewRate.ToString("0.#")%"></i></div></td></tr> }</tbody></table></div></section> }
