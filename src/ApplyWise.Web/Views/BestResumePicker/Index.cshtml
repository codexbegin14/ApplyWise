@model ApplyWise.Web.ViewModels.BestResumePicker.BestResumePickerIndexViewModel
@{
    ViewData["Title"] = "Best Resume Picker";
    var activeTab = "picker";
    var isPastedMode = Model.Mode != "saved";
}

<div class="aw-page aw-fade-in">
    <section class="aw-tool-hero aw-tool-hero-green aw-slide-up"><div><span class="aw-kicker aw-kicker-green"><svg class="ui-icon"><use href="#i-file" /></svg>Best Resume Picker</span><h1>Lead with your strongest version.</h1><p>Compare every readable resume against one role and see exactly why the winner stands out.</p></div></section>
    <partial name="_AnalyzerTabs" model="activeTab" />

    @if (Model.ResumeCount == 0)
    {
        <section class="aw-panel aw-empty-state"><span class="empty-icon" aria-hidden="true"><svg class="ui-icon"><use href="#i-file" /></svg></span><span class="aw-kicker">Your library is empty</span><h2>No resumes to compare yet</h2><p>Upload your first resume version to compare it with saved roles.</p><a class="btn btn-primary" asp-controller="Resumes" asp-action="Create"><svg class="ui-icon"><use href="#i-plus" /></svg>Upload Resume</a></section>
    }
    else
    {
        <section class="aw-panel aw-picker-input aw-slide-up">
            <div class="aw-section-heading"><div><span class="aw-kicker">Comparison source</span><h3>@(isPastedMode ? "Paste the role requirements" : "Choose a saved application")</h3><p>Every readable resume version will be ranked automatically.</p></div><nav class="aw-segmented" aria-label="Comparison source"><a class="@(isPastedMode ? "active" : null)" aria-current="@(isPastedMode ? "page" : null)" asp-action="Index">Paste requirements</a><a class="@(!isPastedMode ? "active" : null)" aria-current="@(!isPastedMode ? "page" : null)" asp-action="Index" asp-route-mode="saved" asp-route-jobApplicationId="@Model.JobApplicationId">Saved application</a></nav></div>
            @if (isPastedMode)
            {
                <form asp-action="CompareResumesWithPastedRequirements" method="post" class="aw-guided-form"><label class="aw-field"><span class="aw-field-label"><b>1</b><span><strong>Job requirements</strong><small>Paste skills, tools, and qualifications from the listing.</small></span></span><textarea asp-for="JobRequirements" class="form-control requirements-textarea" rows="9" placeholder="Paste the role responsibilities, required skills, tools, experience, and qualifications..."></textarea><span class="aw-textarea-meta"><small>Minimum 30 characters</small><small>@Model.ResumeCount resumes will be compared</small></span><span asp-validation-for="JobRequirements" class="field-validation-error"></span></label><button class="btn btn-primary btn-analyze" type="submit"><svg class="ui-icon"><use href="#i-spark" /></svg>Compare All Resumes <span>→</span></button></form>
            }
            else if (Model.AvailableJobApplications.Count == 0)
            {
                <div class="aw-inline-notice"><div><strong>No saved descriptions available</strong><p>Add a job description to an application before comparing.</p></div><a class="btn btn-sm btn-primary" asp-controller="JobApplications" asp-action="Create">Add Application</a></div>
            }
            else
            {
                <form asp-action="Compare" method="post" class="aw-picker-row"><label class="aw-field"><span class="aw-field-label"><b>1</b><span><strong>Saved application</strong><small>We will use its stored requirements.</small></span></span><select asp-for="JobApplicationId" asp-items="Model.AvailableJobApplications" class="form-select"><option value="">Select an application</option></select><span asp-validation-for="JobApplicationId" class="field-validation-error"></span></label><button class="btn btn-primary" type="submit"><svg class="ui-icon"><use href="#i-spark" /></svg>Compare Resumes</button></form>
            }
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
        </section>

        @if (Model.JobDescriptionRequiredId.HasValue) { <section class="aw-inline-notice aw-notice-warning"><div><strong>This role needs a job description</strong><p>Add its requirements so ApplyWise can make a meaningful comparison.</p></div><a class="btn btn-secondary-soft" asp-controller="JobApplications" asp-action="Edit" asp-route-id="@Model.JobDescriptionRequiredId">Edit Application</a></section> }
    }

    @if (Model.Comparison is not null)
    {
        var result = Model.Comparison;
        var recommended = result.RecommendedResume;
        <section class="aw-picker-results aw-slide-up" aria-labelledby="picker-results-title">
            <div class="aw-results-heading"><span class="aw-kicker">Comparison complete</span><h2 id="picker-results-title">@result.ContextTitle</h2><p>@result.ReadableResumeCount of @result.ComparedResumeCount resume@(result.ComparedResumeCount == 1 ? "" : "s") could be analyzed.</p></div>
            @if (recommended is not null)
            {
                <article class="aw-panel aw-recommendation-card"><div class="aw-recommendation-copy"><span class="aw-status aw-status-success">Recommended</span><h3>@recommended.VersionName</h3><p>@result.RecommendationReason</p><small>@recommended.OriginalFileName</small><div class="aw-progress aw-progress-large" role="progressbar" aria-label="ApplyWise Fit for @recommended.VersionName" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@recommended.MatchScore"><i style="--aw-progress:@recommended.MatchScore%"></i></div><span class="aw-coverage-copy">Ranked by ApplyWise Fit, requirement coverage, evidence, and ATS Readiness.</span></div><div class="aw-recommendation-score"><strong>@recommended.MatchScore%</strong><small>ApplyWise Fit</small>@if (result.JobApplicationId.HasValue) { <form asp-action="UseResume" method="post"><input type="hidden" name="JobApplicationId" value="@result.JobApplicationId" /><input type="hidden" name="ResumeId" value="@recommended.ResumeId" /><button class="btn btn-primary" type="submit">Use This Resume</button></form> }</div></article>
            }
            else if (result.ReadableResumeCount == 0) { <div class="aw-inline-notice aw-notice-warning"><div><strong>No readable resumes were available</strong><p>Upload a text-based PDF and run the comparison again.</p></div></div> }
            else if (!result.HasDetectedSkills) { <div class="aw-inline-notice aw-notice-warning"><div><strong>Not enough skill data detected</strong><p>Add specific tools, technologies, and requirements before choosing a resume.</p></div></div> }

            <div class="aw-section-heading aw-ranking-heading"><div><span class="aw-kicker">Full ranking</span><h3>How every version compares</h3></div></div>
            <div class="aw-ranked-list">
                @foreach (var resume in result.ComparedResumes)
                {
                    <article class="aw-card aw-ranked-card @(resume.IsRecommended ? "is-recommended" : null)">
                        <span class="aw-rank">@(resume.Rank.HasValue ? $"#{resume.Rank}" : "-")</span>
                        <div class="aw-ranked-main"><div class="aw-ranked-heading"><div><h3>@resume.VersionName @if (resume.IsRecommended) { <span class="aw-status aw-status-success">Recommended</span> }</h3><p>@resume.OriginalFileName</p></div><strong class="aw-rank-score">@(resume.MatchScore.HasValue ? $"{resume.MatchScore}%" : "N/A")</strong></div>
                            @if (resume.MatchScore.HasValue) { <div class="aw-progress" role="progressbar" aria-label="ApplyWise Fit for @resume.VersionName" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@resume.MatchScore"><i style="--aw-progress:@resume.MatchScore%"></i></div> }
                            @if (resume.AnalysisError is not null) { <p class="resume-analysis-error">@resume.AnalysisError</p> } else { <div class="aw-ranked-skills"><div><span>Matched</span><div class="aw-skill-cloud">@if (resume.MatchedKeywords.Count == 0) { <small class="aw-muted">None detected</small> } else { @foreach (var skill in resume.MatchedKeywords.Take(6)) { <span class="aw-chip aw-chip-green">@skill</span> } }</div></div><div><span>Missing</span><div class="aw-skill-cloud">@if (resume.MissingKeywords.Count == 0) { <small class="aw-muted">None detected</small> } else { @foreach (var skill in resume.MissingKeywords.Take(6)) { <span class="aw-chip aw-chip-amber">@skill</span> } }</div></div></div> }
                        </div>
                        @if (resume.MatchScore.HasValue && result.JobApplicationId.HasValue) { <form asp-action="UseResume" method="post"><input type="hidden" name="JobApplicationId" value="@result.JobApplicationId" /><input type="hidden" name="ResumeId" value="@resume.ResumeId" /><button class="btn btn-secondary-soft btn-sm" type="submit">Use This Resume</button></form> }
                    </article>
                }
            </div>
        </section>
    }
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
