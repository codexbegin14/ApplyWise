@model ApplyWise.Web.ViewModels.Interviews.InterviewIndexViewModel
@{ ViewData["Title"] = "Interviews"; }

<div class="page-heading"><div><h1>Interviews</h1><p>Keep track of interview schedules, preparation notes, and outcomes.</p></div><a class="btn btn-primary" asp-action="Create"><svg class="ui-icon"><use href="#i-plus" /></svg>Add Interview</a></div>
@if (TempData["SuccessMessage"] is string successMessage) { <div class="alert app-alert" role="status">@successMessage</div> }
<nav class="filter-tabs" aria-label="Interview filters"><a class="@(Model.Filter == "upcoming" ? "active" : null)" aria-current="@(Model.Filter == "upcoming" ? "page" : null)" asp-action="Index" asp-route-filter="upcoming">Upcoming</a><a class="@(Model.Filter == "past" ? "active" : null)" aria-current="@(Model.Filter == "past" ? "page" : null)" asp-action="Index" asp-route-filter="past">Past</a><a class="@(Model.Filter == "all" ? "active" : null)" aria-current="@(Model.Filter == "all" ? "page" : null)" asp-action="Index" asp-route-filter="all">All</a></nav>

@if (Model.Interviews.Count == 0)
{
    <section class="panel empty-state"><span class="empty-icon" aria-hidden="true"><svg class="ui-icon"><use href="#i-calendar" /></svg></span><h2>@EmptyTitle()</h2><p>@(Model.Filter == "upcoming" ? "Schedule an interview to keep preparation and timing in one place." : "No interviews match this view yet.")</p>@if (Model.Filter == "upcoming") { <a class="btn btn-primary" asp-action="Create"><svg class="ui-icon"><use href="#i-plus" /></svg>Add Interview</a> }</section>
}
else
{
    <section class="panel schedule-list-panel"><div class="table-responsive"><table class="table app-table schedule-table"><thead><tr><th>Role</th><th>Interview</th><th>Date and time</th><th>Status</th><th>Meeting</th><th><span class="visually-hidden">Actions</span></th></tr></thead><tbody>
    @foreach (var interview in Model.Interviews)
    {
        <tr><td data-label="Role"><div class="application-role"><strong>@interview.JobTitle</strong><span>@interview.CompanyName</span></div></td><td data-label="Interview">@interview.InterviewType.GetDisplayName()</td><td data-label="Date and time"><time datetime="@interview.ScheduledAt.ToString("O")">@interview.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")</time></td><td data-label="Status"><span class="badge @StatusClass(interview.Status)">@interview.Status.GetDisplayName()</span></td><td data-label="Meeting">@if (interview.MeetingLink is not null) { <a href="@interview.MeetingLink" target="_blank" rel="noopener noreferrer">Join meeting</a> } else { <span class="muted-value">Not added</span> }</td><td data-label="Actions"><div class="table-actions"><a asp-action="Details" asp-route-id="@interview.Id">View</a><a asp-action="Edit" asp-route-id="@interview.Id">Edit</a><a class="text-danger" asp-action="Delete" asp-route-id="@interview.Id">Delete</a></div></td></tr>
    }
    </tbody></table></div></section>
}

@functions {
    private string EmptyTitle() => Model.Filter switch { "past" => "No past interviews", "all" => "No interviews yet", _ => "No upcoming interviews" };
    private static string StatusClass(InterviewStatus status) => status switch { InterviewStatus.Scheduled => "status-applied", InterviewStatus.Completed => "status-saved", InterviewStatus.Passed => "status-offer", InterviewStatus.Failed or InterviewStatus.Cancelled => "status-rejected", InterviewStatus.WaitingFeedback => "status-interview", InterviewStatus.Rescheduled => "status-shortlisted", _ => "status-saved" };
}
