@model ApplyWise.Web.ViewModels.Interviews.InterviewDetailsViewModel
@{ ViewData["Title"] = "Delete Interview"; }
<div class="page-heading"><div><h2>Delete Interview</h2><p>Review this scheduled event before removing it.</p></div></div>
<section class="panel confirmation-panel"><span class="danger-mark" aria-hidden="true">!</span><h3>Delete @Model.InterviewType.GetDisplayName()?</h3><p>This removes the interview for <strong>@Model.JobTitle at @Model.CompanyName</strong>, scheduled for @Model.ScheduledAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt").</p><form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="form-actions"><button class="btn btn-danger" type="submit">Delete Interview</button><a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a></form></section>
