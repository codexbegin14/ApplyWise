@model ApplyWise.Web.ViewModels.Interviews.InterviewDetailsViewModel
@{ ViewData["Title"] = "Interview Details"; }
<div class="page-heading application-details-heading"><div><a class="back-link" asp-action="Index">Back to interviews</a><div class="title-with-badge"><h1>@Model.InterviewType.GetDisplayName()</h1><span class="badge @StatusClass(Model.Status)">@Model.Status.GetDisplayName()</span></div><p>@Model.JobTitle at @Model.CompanyName</p></div><div class="form-actions"><a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit Interview</a><a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a></div></div>
@if (TempData["SuccessMessage"] is string successMessage) { <div class="alert app-alert" role="status">@successMessage</div> }
<section class="panel application-overview"><dl class="details-grid interview-details-grid"><div><dt>Date and time</dt><dd>@Model.ScheduledAt.ToLocalTime().ToString("dddd, MMMM d, yyyy 'at' h:mm tt")</dd></div><div><dt>Interviewer</dt><dd>@(Model.InterviewerName ?? "Not specified")</dd></div><div><dt>Meeting</dt><dd>@if (Model.MeetingLink is not null) { <a href="@Model.MeetingLink" target="_blank" rel="noopener noreferrer">Open meeting link</a> } else { <span>Not added</span> }</dd></div><div><dt>Job application</dt><dd><a asp-controller="JobApplications" asp-action="Details" asp-route-id="@Model.JobApplicationId">View application</a></dd></div></dl></section>
<div class="interview-notes-grid"><section class="panel content-panel"><h3>Preparation notes</h3><p>@(Model.PreparationNotes ?? "No preparation notes added.")</p></section><section class="panel content-panel"><h3>Feedback notes</h3><p>@(Model.FeedbackNotes ?? "No feedback notes added.")</p></section><section class="panel content-panel"><h3>Result and next steps</h3><p>@(Model.ResultNotes ?? "No result notes added.")</p></section></div>
<p class="record-timestamps">Created @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt") · Updated @Model.UpdatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</p>
@functions { private static string StatusClass(InterviewStatus status) => status switch { InterviewStatus.Scheduled => "status-applied", InterviewStatus.Completed => "status-saved", InterviewStatus.Passed => "status-offer", InterviewStatus.Failed or InterviewStatus.Cancelled => "status-rejected", InterviewStatus.WaitingFeedback => "status-interview", InterviewStatus.Rescheduled => "status-shortlisted", _ => "status-saved" }; }
