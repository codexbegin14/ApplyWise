@model ApplyWise.Web.ViewModels.Interviews.InterviewEditViewModel
@{ ViewData["Title"] = "Edit Interview"; }
<div class="page-heading"><div><h2>Edit Interview</h2><p>Update the schedule, preparation, feedback, or outcome.</p></div></div>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="application-form"><input asp-for="Id" type="hidden" /><partial name="_InterviewForm" model="Model" /><div class="form-actions"><button class="btn btn-primary" type="submit">Save Changes</button><a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
