@model ApplyWise.Web.ViewModels.Interviews.InterviewFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

@if (Model.AvailableApplications.Count == 0)
{
    <div class="analyzer-notice"><strong>Add a job application before scheduling an interview.</strong><a asp-controller="JobApplications" asp-action="Create">Add Application</a></div>
}

<section class="panel application-form-section">
    <div class="form-section-heading"><span>1</span><div><h3>Job and schedule</h3><p>Connect the interview to an opportunity and set its timing.</p></div></div>
    <div class="form-grid">
        <div class="form-grid-wide"><label asp-for="JobApplicationId" class="form-label"></label><select asp-for="JobApplicationId" asp-items="Model.AvailableApplications" class="form-select" disabled="@(Model.AvailableApplications.Count == 0)"><option value="">Select an application</option></select><span asp-validation-for="JobApplicationId" class="field-validation-error"></span></div>
        <div><label asp-for="InterviewType" class="form-label"></label><select asp-for="InterviewType" asp-items="Html.GetEnumSelectList<InterviewType>()" class="form-select"></select><span asp-validation-for="InterviewType" class="field-validation-error"></span></div>
        <div><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<InterviewStatus>()" class="form-select"></select><span asp-validation-for="Status" class="field-validation-error"></span></div>
        <div><label asp-for="ScheduledAt" class="form-label"></label><input asp-for="ScheduledAt" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" /><span asp-validation-for="ScheduledAt" class="field-validation-error"></span></div>
    </div>
</section>

<section class="panel application-form-section">
    <div class="form-section-heading"><span>2</span><div><h3>Meeting details</h3><p>Add joining information and the interviewer if known.</p></div></div>
    <div class="form-grid"><div><label asp-for="MeetingLink" class="form-label"></label><input asp-for="MeetingLink" class="form-control" placeholder="https://..." /><span asp-validation-for="MeetingLink" class="field-validation-error"></span></div><div><label asp-for="InterviewerName" class="form-label"></label><input asp-for="InterviewerName" class="form-control" placeholder="Optional" /><span asp-validation-for="InterviewerName" class="field-validation-error"></span></div></div>
</section>

<section class="panel application-form-section">
    <div class="form-section-heading"><span>3</span><div><h3>Preparation and outcome</h3><p>Capture what to prepare and update feedback after the interview.</p></div></div>
    <div class="mb-4"><label asp-for="PreparationNotes" class="form-label"></label><textarea asp-for="PreparationNotes" class="form-control" rows="5" placeholder="Topics, questions, or material to review"></textarea><span asp-validation-for="PreparationNotes" class="field-validation-error"></span></div>
    <div class="form-grid"><div><label asp-for="FeedbackNotes" class="form-label"></label><textarea asp-for="FeedbackNotes" class="form-control" rows="4" placeholder="Feedback received or your observations"></textarea><span asp-validation-for="FeedbackNotes" class="field-validation-error"></span></div><div><label asp-for="ResultNotes" class="form-label"></label><textarea asp-for="ResultNotes" class="form-control" rows="4" placeholder="Outcome and next steps"></textarea><span asp-validation-for="ResultNotes" class="field-validation-error"></span></div></div>
</section>
