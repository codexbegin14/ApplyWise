@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    var displayName = User.FindFirst("display_name")?.Value;
    displayName = string.IsNullOrWhiteSpace(displayName)
        ? User.Identity?.Name?.Split('@')[0] ?? "User"
        : displayName.Trim();
}
<div class="account-links">
@if (SignInManager.IsSignedIn(User)) {
    <a class="account-button" asp-controller="Profile" asp-action="Index" title="Profile"><span class="account-avatar"><img src="/profile/avatar" alt="" onerror="this.style.display='none';" />@displayName[0].ToString().ToUpperInvariant()</span><span class="account-name">@displayName</span></a>
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"><button type="submit" class="btn btn-link logout-button">Log out</button></form>
} else {
    <a class="btn btn-link" asp-area="Identity" asp-page="/Account/Login">Log in</a><a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">Create account</a>
}
</div>
