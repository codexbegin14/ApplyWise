@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isIdentityPage = string.Equals(ViewContext.RouteData.Values["area"]?.ToString(), "Identity", StringComparison.OrdinalIgnoreCase);
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ApplyWise helps job seekers track applications, choose the right resume, and apply smarter." />
    <title>@ViewData["Title"] - ApplyWise</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/release.css" asp-append-version="true" />
</head>
<body class="@(isAuthenticated ? "app-body" : isIdentityPage ? "public-body identity-body" : "public-body")">
<svg class="icon-sprite" aria-hidden="true">
    <symbol id="i-grid" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/></symbol>
    <symbol id="i-briefcase" viewBox="0 0 24 24"><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 10h18M5 7h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z"/></symbol>
    <symbol id="i-file" viewBox="0 0 24 24"><path d="M6 2h8l4 4v16H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Z"/><path d="M14 2v5h5M8 12h8M8 16h6"/></symbol>
    <symbol id="i-spark" viewBox="0 0 24 24"><path d="m12 3 1.3 4.2L17 9l-3.7 1.8L12 15l-1.3-4.2L7 9l3.7-1.8L12 3ZM19 15l.7 2.3L22 18l-2.3.7L19 21l-.7-2.3L16 18l2.3-.7L19 15ZM5 13l.8 2.2L8 16l-2.2.8L5 19l-.8-2.2L2 16l2.2-.8L5 13Z"/></symbol>
    <symbol id="i-calendar" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></symbol>
    <symbol id="i-bell" viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9ZM10 21h4"/></symbol>
    <symbol id="i-chart" viewBox="0 0 24 24"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/></symbol>
    <symbol id="i-settings" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1-2.8 2.8-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2h-4V21a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1L4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9A1.7 1.7 0 0 0 3 14H2.8v-4H3a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.2 7 7 4.2l.1.1a1.7 1.7 0 0 0 1.9.3A1.7 1.7 0 0 0 10 3V2.8h4V3a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1L19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.2v4H21a1.7 1.7 0 0 0-1.6 1Z"/></symbol>
    <symbol id="i-plus" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></symbol>
    <symbol id="i-search" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></symbol>
    <symbol id="i-arrow" viewBox="0 0 24 24"><path d="M5 12h14M14 7l5 5-5 5"/></symbol>
</svg>
<a class="skip-link" href="#main-content">Skip to main content</a>
@if (isAuthenticated)
{
    <div class="app-shell">
        <aside class="app-sidebar" id="appSidebar">
            <a class="brand" asp-controller="Dashboard" asp-action="Index"><span class="brand-mark">A<span>W</span></span><span>ApplyWise</span></a>
            <nav class="sidebar-nav" aria-label="Main navigation">
                <a class="@(controller == "Dashboard" && action != "Settings" ? "active" : null)" asp-controller="Dashboard" asp-action="Index"><svg class="ui-icon"><use href="#i-grid" /></svg>Dashboard</a>
                <a class="@(controller == "JobApplications" ? "active" : null)" asp-controller="JobApplications" asp-action="Index"><svg class="ui-icon"><use href="#i-briefcase" /></svg>Applications</a>
                <a class="@(controller == "Resumes" ? "active" : null)" asp-controller="Resumes" asp-action="Index"><svg class="ui-icon"><use href="#i-file" /></svg>Resumes</a>
                <a class="@(controller is "ResumeAnalyzer" or "BestResumePicker" ? "active" : null)" asp-controller="ResumeAnalyzer" asp-action="Index"><svg class="ui-icon"><use href="#i-spark" /></svg>Resume tools</a>
                <a class="@(controller == "Interviews" ? "active" : null)" asp-controller="Interviews" asp-action="Index"><svg class="ui-icon"><use href="#i-calendar" /></svg>Interviews</a>
                <a class="@(controller == "Reminders" ? "active" : null)" asp-controller="Reminders" asp-action="Index"><svg class="ui-icon"><use href="#i-bell" /></svg>Reminders</a>
                <a class="@(controller is "Analytics" or "JobScamChecks" ? "active" : null)" asp-controller="Analytics" asp-action="Index"><svg class="ui-icon"><use href="#i-chart" /></svg>Insights</a>
                <a class="@(controller == "Dashboard" && action == "Settings" ? "active" : null)" asp-controller="Dashboard" asp-action="Settings"><svg class="ui-icon"><use href="#i-settings" /></svg>Settings</a>
            </nav>
            <div class="sidebar-footer"><span class="status-dot"></span> Workspace ready</div>
        </aside>
        <div class="app-main">
            <header class="topbar">
                <button class="menu-button" type="button" data-sidebar-toggle aria-label="Toggle navigation" aria-controls="appSidebar" aria-expanded="false"><span></span><span></span><span></span></button>
                <h1>@ViewData["Title"]</h1>
                <div class="topbar-actions">
                    <form class="search-box" asp-controller="JobApplications" asp-action="Index" method="get" role="search">
                        <label class="visually-hidden" for="globalSearch">Search applications</label>
                        <input id="globalSearch" name="SearchTerm" type="search" placeholder="Search applications..." />
                    </form>
                    <a class="btn btn-primary" asp-controller="JobApplications" asp-action="Create"><svg class="ui-icon"><use href="#i-plus" /></svg>Add Application</a>
                    <partial name="_LoginPartial" />
                </div>
            </header>
            <main class="app-content" id="main-content" role="main">@RenderBody()</main>
        </div>
        <button class="sidebar-backdrop" type="button" data-sidebar-toggle aria-label="Close navigation"></button>
    </div>
}
else
{
    <header class="public-header">
        <a class="brand" asp-controller="Home" asp-action="Index"><span class="brand-mark">A<span>W</span></span><span>ApplyWise</span></a>
        <partial name="_LoginPartial" />
    </header>
    <main id="main-content" role="main">@RenderBody()</main>
}
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
