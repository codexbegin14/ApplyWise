<!DOCTYPE html>
<html lang="en"><head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ApplyWise</title><script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@(User.Identity?.IsAuthenticated == true ? "app-body" : "public-body")">
@if (User.Identity?.IsAuthenticated == true) {
    <div class="app-shell">
        <aside class="app-sidebar" id="appSidebar">
            <a class="brand" asp-controller="Dashboard" asp-action="Index"><span class="brand-mark">A</span><span>ApplyWise</span></a>
            <nav class="sidebar-nav" aria-label="Main navigation">
                <a asp-controller="Dashboard" asp-action="Index">Dashboard</a><a asp-controller="Dashboard" asp-action="Applications">Applications</a>
                <a asp-controller="Resumes" asp-action="Index">Resumes</a><a asp-controller="Dashboard" asp-action="ResumeAnalyzer">Resume Analyzer</a>
                <a asp-controller="Dashboard" asp-action="SkillGaps">Skill Gaps</a><a asp-controller="Dashboard" asp-action="Interviews">Interviews</a>
                <a asp-controller="Dashboard" asp-action="Reminders">Reminders</a><a asp-controller="Dashboard" asp-action="Reports">Reports</a>
                <a asp-controller="Dashboard" asp-action="Settings">Settings</a>
            </nav><div class="sidebar-footer"><span class="status-dot"></span> Workspace ready</div>
        </aside>
        <div class="app-main"><header class="topbar">
            <button class="menu-button" type="button" data-sidebar-toggle aria-label="Toggle navigation"><span></span><span></span><span></span></button>
            <h1>@ViewData["Title"]</h1><div class="topbar-actions"><label class="search-box"><span class="visually-hidden">Search applications and resumes</span><input type="search" placeholder="Search applications, resumes..." /></label>
            <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Applications">Add Application</a><partial name="_LoginPartial" /></div>
        </header><main class="app-content" role="main">@RenderBody()</main></div>
        <button class="sidebar-backdrop" type="button" data-sidebar-toggle aria-label="Close navigation"></button>
    </div>
} else {
    <header class="public-header"><a class="brand" asp-controller="Home" asp-action="Index"><span class="brand-mark">A</span><span>ApplyWise</span></a><partial name="_LoginPartial" /></header>
    <main role="main">@RenderBody()</main>
}
<script src="~/lib/jquery/dist/jquery.min.js"></script><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script><script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body></html>
