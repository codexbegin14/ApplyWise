@model ApplyWise.Web.ViewModels.Opportunities.OpportunityFeedViewModel
@using ApplyWise.Web.Models
@{ ViewData["Title"] = "Opportunities"; }
<div class="aw-page aw-fade-in">
    <header class="aw-page-heading"><div><span class="aw-kicker">Find your next step</span><h2>Opportunities built for students</h2><p>Internships, public-sector roles, private jobs, part-time work, and freelance projects.</p></div><a class="btn btn-primary" asp-controller="JobApplications" asp-action="Create">Add application</a></header>
    <nav class="aw-tabs" aria-label="Opportunity categories">
        <a class="@(Model.Query.Category is null ? "active" : null)" asp-action="Index">For you</a>
        @foreach (var category in Enum.GetValues<OpportunityCategory>()) { <a class="@(Model.Query.Category == category ? "active" : null)" asp-action="Index" asp-route-Category="@category">@category</a> }
    </nav>
    <form method="get" class="aw-panel aw-filter-panel" aria-label="Opportunity filters">
        <label><span>Search</span><input class="form-control" name="Search" value="@Model.Query.Search" placeholder="Role, skill, or organization" /></label>
        <label><span>Work mode</span><select class="form-select" name="WorkMode" asp-items="Html.GetEnumSelectList<OpportunityWorkMode>()"><option value="">Any mode</option></select></label>
        <label><span>Sort</span><select class="form-select" name="Sort"><option value="latest">Latest</option><option value="closing" selected="@(Model.Query.Sort == "closing")">Closing soon</option></select></label>
        <label class="aw-check-field"><input type="checkbox" name="NoExperience" value="true" checked="@(Model.Query.NoExperience)" /> <span>No experience required</span></label>
        <button class="btn btn-primary" type="submit">Filter</button>
    </form>
    @if (Model.Items.Count == 0) { <section class="aw-panel aw-empty-state"><img class="aw-avatar" src="~/images/wiso.png" alt="" /><h3>No opportunities match yet</h3><p>Try a broader search or complete your profile so matches can become more useful.</p><a class="btn btn-secondary-soft" asp-controller="Profile" asp-action="Index">Complete profile</a></section> }
    else { <div class="aw-opportunity-grid">@foreach (var item in Model.Items) { <article class="aw-card aw-opportunity-card"><div class="aw-opportunity-top"><span class="aw-opportunity-tag">@item.Category</span>@if(item.IsVerified){<span class="aw-verified">Verified</span>}</div><h3><a asp-action="Details" asp-route-id="@item.Id">@item.Title</a></h3><p class="aw-opportunity-org">@item.OrganizationName · @(item.Location ?? item.WorkMode.ToString())</p><p>@item.Summary</p><div class="aw-opportunity-meta"><span>@item.EmploymentType</span><span>@item.WorkMode</span>@if(item.Deadline.HasValue){<span>Closes @item.Deadline.Value.ToLocalTime().ToString("MMM d")</span>}</div><div class="aw-card-actions"><a class="btn btn-primary btn-sm" asp-action="Details" asp-route-id="@item.Id">View details</a><form method="post" asp-action="Save" asp-route-id="@item.Id"><button class="btn btn-secondary-soft btn-sm" type="submit">@(item.IsSaved ? "Saved" : "Save")</button></form></div></article> }</div> }
    @if (Model.TotalPages > 1) { <nav class="aw-pagination" aria-label="Opportunity pages">@for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++) { <a class="@(pageNumber == Model.Page ? "active" : null)" asp-action="Index" asp-route-Page="@pageNumber" asp-route-Category="@Model.Query.Category" asp-route-WorkMode="@Model.Query.WorkMode" asp-route-Search="@Model.Query.Search" asp-route-Sort="@Model.Query.Sort">@pageNumber</a> }</nav> }
</div>
