@model ApplyWise.Web.Models.Opportunity
@{ ViewData["Title"] = Model.Title; }
<div class="aw-page aw-fade-in"><a class="aw-back-link" asp-action="Index">← All opportunities</a><article class="aw-panel aw-opportunity-detail"><div class="aw-opportunity-top"><span class="aw-opportunity-tag">@Model.Category</span>@if(Model.IsVerified){<span class="aw-verified">Verified</span>}</div><h1>@Model.Title</h1><p class="aw-opportunity-org">@Model.OrganizationName · @(Model.Location ?? Model.WorkMode.ToString())</p><p class="aw-opportunity-summary">@Model.Summary</p><div class="aw-opportunity-meta"><span>@Model.EmploymentType</span><span>@Model.WorkMode</span>@if(Model.Compensation != null){<span>@Model.Compensation</span>}</div><div class="aw-detail-copy"><h2>What you’ll do</h2><p>@(Model.Description ?? "The organization has not added more detail yet.")</p>@if(Model.Requirements != null){<h2>Requirements</h2><p>@Model.Requirements</p>}@if(Model.Skills != null){<h2>Skills</h2><p>@Model.Skills</p>}</div><div class="aw-card-actions"><a class="btn btn-primary" href="@Model.ApplicationUrl" target="_blank" rel="noopener noreferrer">Apply on source</a><a class="btn btn-secondary-soft" asp-controller="JobApplications" asp-action="Create" asp-route-opportunityId="@Model.Id">Track application</a></div></article></div>
