@model ApplyWise.Web.ViewModels.Reminders.ReminderEditViewModel
@{ ViewData["Title"] = "Edit Reminder"; }
<div class="page-heading"><div><h2>Edit Reminder</h2><p>Update the timing, related job, or action details.</p></div></div>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="application-form"><input asp-for="Id" type="hidden" /><partial name="_ReminderForm" model="Model" /><div class="form-actions"><button class="btn btn-primary" type="submit">Save Changes</button><a class="btn btn-outline-secondary" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
