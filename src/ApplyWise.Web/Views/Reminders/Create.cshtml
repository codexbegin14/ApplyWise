@model ApplyWise.Web.ViewModels.Reminders.ReminderCreateViewModel
@{ ViewData["Title"] = "Add Reminder"; }
<div class="page-heading"><div><h2>Add Reminder</h2><p>Plan a follow-up, deadline, or standalone next action.</p></div></div>
<form asp-action="Create" method="post" class="application-form"><partial name="_ReminderForm" model="Model" /><div class="form-actions"><button class="btn btn-primary" type="submit">Save Reminder</button><a class="btn btn-outline-secondary" asp-action="Index">Cancel</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
