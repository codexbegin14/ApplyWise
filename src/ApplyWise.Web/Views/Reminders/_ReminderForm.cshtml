@model ApplyWise.Web.ViewModels.Reminders.ReminderFormViewModel
<div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
<section class="panel reminder-form-card">
    <div class="form-section-heading"><span>1</span><div><h3>Next action</h3><p>Set what needs attention, when it is due, and the related job if any.</p></div></div>
    <div class="form-grid"><div class="form-grid-wide"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" placeholder="e.g. Follow up with hiring manager" /><span asp-validation-for="Title" class="field-validation-error"></span></div><div><label asp-for="ReminderType" class="form-label"></label><select asp-for="ReminderType" asp-items="Html.GetEnumSelectList<ReminderType>()" class="form-select"></select><span asp-validation-for="ReminderType" class="field-validation-error"></span></div><div><label asp-for="DueAt" class="form-label"></label><input asp-for="DueAt" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" /><span asp-validation-for="DueAt" class="field-validation-error"></span></div><div class="form-grid-wide"><label asp-for="JobApplicationId" class="form-label"></label><select asp-for="JobApplicationId" asp-items="Model.AvailableApplications" class="form-select"><option value="">Standalone reminder</option></select><span asp-validation-for="JobApplicationId" class="field-validation-error"></span></div></div>
</section>
<section class="panel reminder-form-card"><div class="form-section-heading"><span>2</span><div><h3>Notes</h3><p>Add context so the next action is easy to complete.</p></div></div><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="5" placeholder="Contact details, documents, or what to say"></textarea><span asp-validation-for="Notes" class="field-validation-error"></span></section>
