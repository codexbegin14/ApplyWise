@model IReadOnlyList<ApplyWise.Web.Models.Opportunity>
@{ ViewData["Title"] = "Manage opportunities"; }
<div class="aw-page"><header class="aw-page-heading"><div><span class="aw-kicker">Announcement portal</span><h2>Manage opportunities</h2></div><a class="btn btn-primary" asp-action="Create">Add opportunity</a></header><div class="aw-panel aw-table-wrap"><table class="table"><thead><tr><th>Role</th><th>Category</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var item in Model){<tr><td><strong>@item.Title</strong><br /><small>@item.OrganizationName</small></td><td>@item.Category</td><td>@item.Status</td><td><form method="post" asp-action="Status" asp-route-id="@item.Id"><select name="status" class="form-select form-select-sm"><option value="Draft">Draft</option><option value="Published">Publish</option><option value="Archived">Archive</option></select><button class="btn btn-sm btn-secondary-soft" type="submit">Update</button></form></td></tr>}</tbody></table></div></div>
