@model ApplyWise.Web.ViewModels.Opportunities.OpportunityCreateViewModel
@using ApplyWise.Web.Models
@{ ViewData["Title"] = "Add opportunity"; }
<div class="aw-page"><section class="aw-panel aw-form-panel"><span class="aw-kicker">Announcement portal</span><h1>Add an opportunity</h1><p>New listings start as drafts and need a manager review before publishing.</p><form method="post"><div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div><div class="form-grid"><div><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="field-validation-error"></span></div><div><label asp-for="OrganizationName" class="form-label"></label><input asp-for="OrganizationName" class="form-control" /></div><div><label asp-for="Category" class="form-label"></label><select asp-for="Category" asp-items="Html.GetEnumSelectList<OpportunityCategory>()" class="form-select"></select></div><div><label asp-for="EmploymentType" class="form-label"></label><select asp-for="EmploymentType" asp-items="Html.GetEnumSelectList<OpportunityEmploymentType>()" class="form-select"></select></div><div><label asp-for="WorkMode" class="form-label"></label><select asp-for="WorkMode" asp-items="Html.GetEnumSelectList<OpportunityWorkMode>()" class="form-select"></select></div><div><label asp-for="Location" class="form-label"></label><input asp-for="Location" class="form-control" /></div><div class="form-grid-wide"><label asp-for="Summary" class="form-label"></label><textarea asp-for="Summary" class="form-control" rows="3"></textarea></div><div class="form-grid-wide"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="8"></textarea></div><div><label asp-for="ApplicationUrl" class="form-label"></label><input asp-for="ApplicationUrl" class="form-control" /></div><div><label asp-for="SourceUrl" class="form-label"></label><input asp-for="SourceUrl" class="form-control" /></div><div><label asp-for="Deadline" class="form-label"></label><input asp-for="Deadline" class="form-control" /></div></div><button class="btn btn-primary" type="submit">Save draft</button></form></section></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
