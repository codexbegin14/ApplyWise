@model ApplyWise.Web.ViewModels.ResumeAnalyzer.AnalyzerIndexViewModel
@{
    ViewData["Title"] = "Resume Analyzer";
    var isPastedMode = Model.Mode != "saved";
    var activeTab = isPastedMode ? "pasted" : "saved";
    var hasResumes = Model.AvailableResumes.Count > 0;
}

<div class="page-heading">
    <div><h2>Resume Analyzer</h2><p>Paste job requirements or choose a saved application to compare your resume.</p></div>
</div>
<partial name="_AnalyzerTabs" model="activeTab" />

<div class="analyzer-layout">
    <section class="panel analyzer-form-card">
        @if (!hasResumes)
        {
            <div class="analyzer-notice"><strong>Upload a resume before running analysis.</strong><a asp-controller="Resumes" asp-action="Create">Upload Resume</a></div>
        }

        @if (isPastedMode)
        {
            <div class="panel-header"><div><h3>Paste job requirements</h3><p>Use requirements copied from LinkedIn, WhatsApp, email, or a company website.</p></div></div>
            <form asp-action="AnalyzePastedRequirements" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
                <div class="analyzer-fields analyzer-fields-stacked">
                    <div><label asp-for="Pasted.ResumeId" class="form-label"></label><select asp-for="Pasted.ResumeId" asp-items="Model.AvailableResumes" class="form-select" disabled="@(!hasResumes)"><option value="">Select a resume</option></select><span asp-validation-for="Pasted.ResumeId" class="field-validation-error"></span></div>
                    <div><label asp-for="Pasted.JobRequirements" class="form-label"></label><textarea asp-for="Pasted.JobRequirements" class="form-control requirements-textarea" rows="11" placeholder="Paste the role responsibilities, required skills, tools, experience, and qualifications here..."></textarea><div class="form-hint">At least 30 characters. Include specific skills for a more useful comparison.</div><span asp-validation-for="Pasted.JobRequirements" class="field-validation-error"></span></div>
                </div>
                <button class="btn btn-primary" type="submit" disabled="@(!hasResumes)">Analyze Resume</button>
            </form>
        }
        else
        {
            <div class="panel-header"><div><h3>Analyze a saved application</h3><p>Compare a resume with the job description stored in your application tracker.</p></div></div>
            @if (Model.AvailableJobApplications.Count == 0)
            {
                <div class="analyzer-notice"><strong>Add an application with a job description before using this mode.</strong><a asp-controller="JobApplications" asp-action="Create">Add Application</a></div>
            }
            <form asp-action="AnalyzeSavedApplication" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
                <div class="analyzer-fields">
                    <div><label asp-for="Saved.ResumeId" class="form-label"></label><select asp-for="Saved.ResumeId" asp-items="Model.AvailableResumes" class="form-select" disabled="@(!hasResumes)"><option value="">Select a resume</option></select><span asp-validation-for="Saved.ResumeId" class="field-validation-error"></span></div>
                    <div><label asp-for="Saved.JobApplicationId" class="form-label"></label><select asp-for="Saved.JobApplicationId" asp-items="Model.AvailableJobApplications" class="form-select" disabled="@(Model.AvailableJobApplications.Count == 0)"><option value="">Select an application</option></select><span asp-validation-for="Saved.JobApplicationId" class="field-validation-error"></span></div>
                </div>
                <button class="btn btn-primary" type="submit" disabled="@(!hasResumes || Model.AvailableJobApplications.Count == 0)">Analyze Resume</button>
            </form>
        }
    </section>

    <aside class="panel analyzer-method-card">
        <span class="method-label">Local analysis</span>
        <h3>Clear, explainable matching</h3>
        <p>ApplyWise detects known skills in the requirements, checks which appear in your resume, and calculates direct coverage.</p>
        <small>Your resume and pasted requirements are not sent to an external AI service.</small>
    </aside>
</div>

@if (Model.LatestResult is not null)
{
    <partial name="_AnalysisResult" model="Model.LatestResult" />
}

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
