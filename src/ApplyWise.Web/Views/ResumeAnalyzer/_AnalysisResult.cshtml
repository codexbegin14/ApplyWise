@model ApplyWise.Web.ViewModels.ResumeAnalyzer.AnalysisResultViewModel
@{
    var resultId = $"analysis-result-{Model.Id}";
    var visibleSuggestions = Model.Suggestions.Take(5).ToArray();
}

<section id="@resultId"
         class="aw-ra-result aw-slide-up"
         data-analysis-result="@Model.Id"
         tabindex="-1"
         aria-labelledby="@($"{resultId}-title")">
    <header class="aw-ra-result-header">
        <div>
            <span class="aw-kicker">Saved analysis</span>
            <h2 id="@($"{resultId}-title")">@Model.ContextTitle</h2>
            <p>
                <strong>@Model.ResumeVersionName</strong>
                <span aria-hidden="true">&middot;</span>
                @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")
                @if (!string.IsNullOrWhiteSpace(Model.ContextSubtitle))
                {
                    <span aria-hidden="true">&middot;</span>
                    @Model.ContextSubtitle
                }
            </p>
        </div>
        <a class="btn btn-primary btn-sm"
           asp-controller="ResumeAnalyzer"
           asp-action="Index"
           asp-route-analysisId="@Model.Id">
            Re-run analysis
        </a>
    </header>

    <div class="aw-ra-legacy-notice" role="note" aria-label="Legacy score notice">
        <span class="aw-ra-notice-icon" aria-hidden="true">i</span>
        <p><strong>Legacy score.</strong> Re-run this resume to get the latest ATS checks and recommendations.</p>
    </div>

    <section class="aw-ra-legacy-score @ScoreTone(Model.OverallScore)" aria-labelledby="@($"{resultId}-score")">
        <div class="aw-ra-score-ring"
             style="--aw-ra-score: @Model.OverallScore"
             role="progressbar"
             aria-label="Legacy match score: @Model.OverallScore out of 100"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-valuenow="@Model.OverallScore">
            <strong>@Model.OverallScore</strong>
            <small>out of 100</small>
        </div>
        <div>
            <span class="aw-kicker">Resume score</span>
            <h3 id="@($"{resultId}-score")">@ScoreBand(Model.OverallScore)</h3>
            <p>This historical result used the earlier keyword-based scoring method.</p>
        </div>
    </section>

    <div class="aw-ra-two-column">
        <section class="aw-ra-panel" aria-labelledby="@($"{resultId}-matched")">
            <div class="aw-ra-panel-heading">
                <h3 id="@($"{resultId}-matched")">Matched keywords</h3>
                <span class="aw-ra-count" aria-label="@Model.MatchedKeywords.Count matched keywords">@Model.MatchedKeywords.Count</span>
            </div>
            @if (Model.MatchedKeywords.Count == 0)
            {
                <p class="aw-ra-empty">No matched keywords were saved.</p>
            }
            else
            {
                <div class="aw-ra-chip-list">
                    @foreach (var keyword in Model.MatchedKeywords)
                    {
                        <span class="aw-ra-chip is-positive">@keyword</span>
                    }
                </div>
            }
        </section>

        <section class="aw-ra-panel" aria-labelledby="@($"{resultId}-missing")">
            <div class="aw-ra-panel-heading">
                <h3 id="@($"{resultId}-missing")">Missing keywords</h3>
                <span class="aw-ra-count" aria-label="@Model.MissingKeywords.Count missing keywords">@Model.MissingKeywords.Count</span>
            </div>
            @if (Model.MissingKeywords.Count == 0)
            {
                <p class="aw-ra-empty">No missing keywords were saved.</p>
            }
            else
            {
                <div class="aw-ra-chip-list">
                    @foreach (var keyword in Model.MissingKeywords)
                    {
                        <span class="aw-ra-chip is-warning">@keyword</span>
                    }
                </div>
            }
        </section>
    </div>

    <section class="aw-ra-panel" aria-labelledby="@($"{resultId}-suggestions")">
        <div class="aw-ra-panel-heading">
            <div>
                <span class="aw-kicker">Next steps</span>
                <h3 id="@($"{resultId}-suggestions")">How to improve</h3>
            </div>
        </div>
        @if (visibleSuggestions.Length == 0)
        {
            <p class="aw-ra-empty">No suggestions were saved with this result.</p>
        }
        else
        {
            <ol class="aw-ra-numbered-list">
                @foreach (var suggestion in visibleSuggestions)
                {
                    <li>@suggestion</li>
                }
            </ol>
        }
    </section>

    <footer class="aw-ra-disclaimer">
        <strong>Keep every update accurate</strong>
        <p>This is an ApplyWise estimate, not an employer ATS score, and it cannot guarantee an interview or hiring outcome.</p>
    </footer>
</section>

@functions {
    private static string ScoreTone(int score) => score switch
    {
        >= 85 => "is-strong",
        >= 70 => "is-good",
        >= 50 => "is-developing",
        _ => "is-low"
    };

    private static string ScoreBand(int score) => score switch
    {
        >= 85 => "Strong alignment",
        >= 70 => "Good alignment",
        >= 50 => "Needs targeted improvement",
        _ => "Significant gaps"
    };
}
