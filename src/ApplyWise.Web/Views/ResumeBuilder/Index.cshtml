@model ApplyWise.Web.ViewModels.ResumeBuilder.ResumeBuilderPageViewModel
@{
    ViewData["Title"] = "Resume Builder";
}

@section Styles {
    <link rel="stylesheet" href="~/css/resume-builder.css" asp-append-version="true" />
}

<div class="aw-page aw-resume-builder aw-fade-in"
     data-resume-builder
     data-draft-key="@Model.DraftStorageKey"
     data-initial-section="@Model.InitialSection"
     data-gallery-photo-url="@Url.Content("~/images/wiso.png")">
    <textarea data-sample-resume hidden aria-hidden="true" tabindex="-1">@Model.SampleResumeJson</textarea>

    <section id="rb-template-gallery" class="aw-rb-template-gallery" data-template-gallery aria-labelledby="rb-template-gallery-title" hidden>
        <header class="aw-rb-template-gallery-header">
            <div>
                <span class="aw-kicker aw-kicker-violet">15 professional resume designs</span>
                <h1 id="rb-template-gallery-title">Choose the resume that fits your next opportunity.</h1>
                <p>Every card is rendered from the same PDF definition used for preview and download. You can change designs later without losing your details.</p>
            </div>
            <button class="btn btn-secondary-soft" type="button" data-action="exit-template-gallery" data-gallery-cancel hidden>
                Back to editor
            </button>
        </header>

        <div class="aw-rb-template-gallery-layout">
            <div class="aw-rb-template-gallery-grid"
                 data-template-gallery-grid
                 role="listbox"
                 aria-label="Resume templates">
                <div class="aw-rb-template-gallery-loading" role="status">
                    <span class="aw-rb-preview-spinner" aria-hidden="true"></span>
                    Preparing real PDF previews…
                </div>
            </div>

        </div>

        <dialog class="aw-rb-template-preview-dialog"
                data-template-preview-dialog
                aria-labelledby="rb-template-preview-title"
                aria-describedby="rb-template-preview-description">
            <div class="aw-rb-template-preview-shell">
                <header class="aw-rb-template-preview-header">
                    <div class="aw-rb-template-preview-copy">
                        <div class="aw-rb-template-preview-title-row">
                            <h2 id="rb-template-preview-title" data-gallery-name>Editorial</h2>
                            <span class="aw-rb-template-classification" data-gallery-classification>ATS-optimized</span>
                        </div>
                        <p id="rb-template-preview-description" data-gallery-description>
                            A refined photo-free resume with formal two-column structure.
                        </p>
                    </div>

                    <div class="aw-rb-template-preview-actions" aria-label="Template preview actions">
                        <button type="button" data-action="previous-gallery-template">
                            <span aria-hidden="true">&larr;</span> Previous
                        </button>
                        <button type="button" data-action="next-gallery-template">
                            Next <span aria-hidden="true">&rarr;</span>
                        </button>
                        <button class="is-primary" type="button" data-action="choose-gallery-template">
                            Use template
                        </button>
                        <button class="aw-rb-template-preview-close"
                                type="button"
                                data-action="close-template-preview"
                                aria-label="Close template preview">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                </header>

                <div class="aw-rb-template-preview-body">
                    <div class="aw-rb-template-gallery-sheet" aria-live="polite">
                        <iframe data-template-gallery-large-preview
                                title="Selected template PDF preview"
                                aria-describedby="rb-template-preview-description"></iframe>
                        <div class="aw-rb-template-gallery-preview-state" data-template-gallery-preview-state>
                            Preparing template previewâ€¦
                        </div>
                    </div>

                </div>
            </div>
        </dialog>
    </section>

    <header class="aw-rb-hero aw-slide-up">
        <div class="aw-rb-hero-copy">
            <h1>Resume Builder</h1>
            <p>Add your details, choose a template, and download a polished PDF.</p>
            <div class="aw-rb-status-line">
                <span class="aw-rb-save-status" data-save-status role="status" aria-live="polite" aria-atomic="true">
                    Saved in this browser
                </span>
                <span id="rb-pdf-status" class="aw-rb-pdf-status" data-pdf-status role="status" aria-live="polite" aria-atomic="true"></span>
            </div>
        </div>
        <div class="aw-rb-toolbar" aria-label="Resume actions">
            <button class="btn btn-secondary-soft" type="button" data-action="load-sample">
                <span aria-hidden="true">&#10022;</span>
                Sample
            </button>
            <button class="btn aw-rb-danger-button" type="button" data-action="clear">
                Clear
            </button>
            <button class="btn btn-primary aw-rb-download" type="button" data-action="download" aria-describedby="rb-pdf-status" disabled>
                <svg class="aw-rb-button-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 20h14" />
                </svg>
                <span>Download PDF</span>
            </button>
        </div>
        <section class="aw-rb-one-page-guide" data-one-page-guide aria-labelledby="rb-one-page-title">
            <div class="aw-rb-one-page-copy">
                <strong id="rb-one-page-title">One-page check</strong>
                <span class="aw-rb-one-page-hint">We&apos;ll alert you if the resume becomes too long.</span>
            </div>
            <div class="aw-rb-page-fit-status is-checking" data-page-fit-status role="status" aria-live="polite">Checking page fit&hellip;</div>
            <details>
                <summary>Content limits</summary>
                <div class="aw-rb-one-page-metrics" aria-label="Recommended one-page content limits">
                    <span data-guide-metric="professionalSummary">Summary <strong>0 / 3 lines</strong></span>
                    <span data-guide-metric="education">Education <strong>0 / 2</strong></span>
                    <span data-guide-metric="experience">Experience <strong>0 / 3</strong></span>
                    <span data-guide-metric="projects">Projects <strong>0 / 3</strong></span>
                    <span data-guide-metric="achievementsAndCertifications">Achievements <strong>0 / 3</strong></span>
                </div>
            </details>
            <p class="aw-rb-one-page-warning" data-one-page-warning role="alert" hidden></p>
        </section>
    </header>

    <div class="aw-rb-mobile-tabs" role="tablist" aria-label="Resume builder view">
        <button id="rb-editor-tab"
                class="is-active"
                type="button"
                role="tab"
                data-tab="form"
                aria-selected="true"
                aria-controls="rb-editor-panel">
            Editor
        </button>
        <button id="rb-preview-tab"
                type="button"
                role="tab"
                data-tab="preview"
                aria-selected="false"
                aria-controls="rb-preview-panel"
                tabindex="-1">
            Preview
        </button>
    </div>

    <div class="aw-rb-workspace">
        <section id="rb-editor-panel"
                 class="aw-panel aw-rb-editor is-active"
                 data-tab-panel="form"
                 role="tabpanel"
                 aria-labelledby="rb-editor-tab"
                 aria-hidden="false">
            <section class="aw-rb-completion" aria-label="Resume completion">
                <div class="aw-rb-completion-row">
                    <span>
                        <strong data-builder-progress>0%</strong>
                        <span>Resume completeness</span>
                    </span>
                    <span data-builder-next-step>Add your contact details</span>
                </div>
                <div class="aw-rb-completion-track" role="progressbar" aria-label="Resume completeness" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                    <span data-builder-progress-bar></span>
                </div>
            </section>

            <div class="aw-rb-panel-heading">
                <div>
                    <h2>Resume details</h2>
                    <p>Complete each section. Your preview updates automatically.</p>
                </div>
            </div>

            <nav class="aw-rb-editor-tabs" data-editor-tabs role="tablist" aria-label="Resume detail sections">
                <button id="rb-detail-tab-personal" class="is-active" type="button" role="tab" data-editor-tab="personal" aria-selected="true" aria-controls="rb-resume-fields">Contact</button>
                <button id="rb-detail-tab-summary" type="button" role="tab" data-editor-tab="summary" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Profile</button>
                <button id="rb-detail-tab-experience" type="button" role="tab" data-editor-tab="experience" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Experience</button>
                <button id="rb-detail-tab-education" type="button" role="tab" data-editor-tab="education" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Education</button>
                <button id="rb-detail-tab-skills" type="button" role="tab" data-editor-tab="skills" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Skills</button>
                <button id="rb-detail-tab-projects" type="button" role="tab" data-editor-tab="projects" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Projects</button>
                <button id="rb-detail-tab-more" type="button" role="tab" data-editor-tab="more" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">More</button>
                <button id="rb-detail-tab-arrange" type="button" role="tab" data-editor-tab="arrange" aria-selected="false" aria-controls="rb-resume-fields" tabindex="-1">Arrange</button>
            </nav>

            <form id="rb-resume-fields" class="aw-rb-form" data-resume-form role="tabpanel" aria-labelledby="rb-detail-tab-personal" autocomplete="on" novalidate>
                <fieldset class="aw-rb-form-section" data-editor-section="personalInformation">
                    <legend>
                        <span class="aw-rb-section-number">1</span>
                        <span>
                            <strong>Personal information</strong>
                            <small>The contact details employers see first.</small>
                        </span>
                    </legend>

                    <div class="aw-rb-photo-field" data-photo-field hidden>
                        <div class="aw-rb-photo-copy">
                            <span class="aw-kicker aw-kicker-violet">For this template</span>
                            <strong>Add a professional portrait</strong>
                            <small data-photo-template-help>This design includes a profile photo.</small>
                        </div>
                        <div class="aw-rb-photo-controls">
                            <span class="aw-rb-photo-preview" aria-hidden="true">
                                <img data-photo-preview alt="" hidden />
                                <span data-photo-initials>AW</span>
                            </span>
                            <div>
                                <div class="aw-rb-photo-actions">
                                    <label class="btn btn-secondary-soft btn-sm" for="rb-profile-photo" data-photo-picker-label>Choose photo</label>
                                    <button class="aw-rb-photo-remove" type="button" data-action="remove-profile-photo" data-remove-profile-photo hidden>
                                        <span aria-hidden="true">&times;</span>
                                        Remove
                                    </button>
                                </div>
                                <input id="rb-profile-photo"
                                       class="visually-hidden"
                                       type="file"
                                       data-profile-photo-input
                                       aria-describedby="rb-profile-photo-help rb-profile-photo-error"
                                       accept="image/png,image/jpeg,image/webp" />
                                <small id="rb-profile-photo-help">PNG, JPG, or WebP. ApplyWise crops it to a resume-ready portrait.</small>
                                <span class="aw-rb-photo-status" data-photo-status role="status" aria-live="polite"></span>
                                <span id="rb-profile-photo-error" class="aw-rb-error" data-error-for="personalInformation.profilePhotoDataUrl" aria-live="polite"></span>
                            </div>
                        </div>
                    </div>

                    <div class="aw-rb-field-grid">
                        <div class="aw-rb-field aw-rb-field-wide">
                            <label for="rb-full-name">Full name <span aria-hidden="true">*</span></label>
                            <input id="rb-full-name"
                                   class="form-control"
                                   type="text"
                                   data-field="personalInformation.fullName"
                                   autocomplete="name"
                                   maxlength="100"
                                   placeholder="e.g. Jordan Lee"
                                   aria-describedby="rb-full-name-error"
                                   required />
                            <span id="rb-full-name-error" class="aw-rb-error" data-error-for="personalInformation.fullName" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field aw-rb-field-wide">
                            <label for="rb-professional-title">Professional title <span aria-hidden="true">*</span></label>
                            <input id="rb-professional-title"
                                   class="form-control"
                                   type="text"
                                   data-field="personalInformation.professionalTitle"
                                   autocomplete="organization-title"
                                   maxlength="120"
                                   placeholder="e.g. Full-Stack Software Engineer"
                                   aria-describedby="rb-professional-title-error"
                                   required />
                            <span id="rb-professional-title-error" class="aw-rb-error" data-error-for="personalInformation.professionalTitle" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field">
                            <label for="rb-phone">Phone number</label>
                            <input id="rb-phone"
                                   class="form-control"
                                   type="tel"
                                   data-field="personalInformation.phoneNumber"
                                   autocomplete="tel"
                                   inputmode="tel"
                                   maxlength="40"
                                   placeholder="+92 300 1234567"
                                   aria-describedby="rb-phone-error" />
                            <span id="rb-phone-error" class="aw-rb-error" data-error-for="personalInformation.phoneNumber" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field">
                            <label for="rb-email">Email address <span aria-hidden="true">*</span></label>
                            <input id="rb-email"
                                   class="form-control"
                                   type="email"
                                   data-field="personalInformation.emailAddress"
                                   autocomplete="email"
                                   maxlength="254"
                                   placeholder="you@example.com"
                                   aria-describedby="rb-email-error"
                                   required />
                            <span id="rb-email-error" class="aw-rb-error" data-error-for="personalInformation.emailAddress" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field aw-rb-field-wide">
                            <label for="rb-location">Location</label>
                            <input id="rb-location"
                                   class="form-control"
                                   type="text"
                                   data-field="personalInformation.location"
                                   autocomplete="address-level2"
                                   maxlength="120"
                                   placeholder="City, Country"
                                   aria-describedby="rb-location-error" />
                            <span id="rb-location-error" class="aw-rb-error" data-error-for="personalInformation.location" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field">
                            <label for="rb-linkedin">LinkedIn URL</label>
                            <input id="rb-linkedin"
                                   class="form-control"
                                   type="url"
                                   data-field="personalInformation.linkedInUrl"
                                   autocomplete="url"
                                   inputmode="url"
                                   maxlength="500"
                                   placeholder="https://linkedin.com/in/your-name"
                                   aria-describedby="rb-linkedin-error" />
                            <span id="rb-linkedin-error" class="aw-rb-error" data-error-for="personalInformation.linkedInUrl" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field">
                            <label for="rb-github">GitHub URL</label>
                            <input id="rb-github"
                                   class="form-control"
                                   type="url"
                                   data-field="personalInformation.gitHubUrl"
                                   autocomplete="url"
                                   inputmode="url"
                                   maxlength="500"
                                   placeholder="https://github.com/your-name"
                                   aria-describedby="rb-github-error" />
                            <span id="rb-github-error" class="aw-rb-error" data-error-for="personalInformation.gitHubUrl" aria-live="polite"></span>
                        </div>

                        <div class="aw-rb-field aw-rb-field-wide">
                            <label for="rb-portfolio">Portfolio URL</label>
                            <input id="rb-portfolio"
                                   class="form-control"
                                   type="url"
                                   data-field="personalInformation.portfolioUrl"
                                   autocomplete="url"
                                   inputmode="url"
                                   maxlength="500"
                                   placeholder="https://yourportfolio.com"
                                   aria-describedby="rb-portfolio-error" />
                            <span id="rb-portfolio-error" class="aw-rb-error" data-error-for="personalInformation.portfolioUrl" aria-live="polite"></span>
                        </div>
                    </div>
                </fieldset>

                <fieldset class="aw-rb-form-section" data-editor-section="professionalSummary">
                    <legend>
                        <span class="aw-rb-section-number">2</span>
                        <span>
                            <strong>Professional summary</strong>
                            <small>A concise introduction tailored to the work you want.</small>
                        </span>
                    </legend>

                    <div class="aw-rb-field">
                        <label class="visually-hidden" for="rb-summary">Professional summary</label>
                        <div class="aw-rb-format-toolbar" aria-label="Professional summary formatting">
                            <span>Select words, then format them:</span>
                            <div role="group" aria-label="Text formatting">
                                <button type="button" data-format="bold" data-format-target="rb-summary" title="Bold selected text" aria-label="Bold selected summary text"><strong>B</strong></button>
                                <button type="button" data-format="italic" data-format-target="rb-summary" title="Italicize selected text" aria-label="Italicize selected summary text"><span>I</span></button>
                                <button type="button" data-format="underline" data-format-target="rb-summary" title="Underline selected text" aria-label="Underline selected summary text"><span class="aw-rb-underlined">U</span></button>
                            </div>
                        </div>
                        <textarea id="rb-summary"
                                  class="form-control aw-rb-summary"
                                  data-field="professionalSummary"
                                  rows="6"
                                  maxlength="1200"
                                  placeholder="Summarize your experience, strengths, and the value you bring..."
                                  aria-describedby="rb-summary-help rb-summary-error"></textarea>
                        <div id="rb-summary-help" class="aw-rb-field-meta">
                            <span>Aim for about three compact lines. Formatting markers become styles in the PDF.</span>
                            <span data-summary-count>0 / 1,200</span>
                        </div>
                        <span id="rb-summary-error" class="aw-rb-error" data-error-for="professionalSummary" aria-live="polite"></span>
                    </div>
                </fieldset>

                <section class="aw-rb-dynamic-sections" data-dynamic-section-host aria-label="Resume content fields">
                    <div class="aw-rb-section-editor" data-section-editor>
                        <div class="aw-rb-empty">
                            <strong>Preparing your resume editor…</strong>
                            <span>Education, experience, projects, skills, and optional sections will appear here.</span>
                        </div>
                    </div>
                </section>

                <section class="aw-rb-form-section" data-editor-section="arrange" aria-labelledby="rb-section-order-title">
                    <div class="aw-rb-section-heading">
                        <div>
                            <span class="aw-rb-section-number">3</span>
                            <span>
                                <h3 id="rb-section-order-title">Section order and visibility</h3>
                                <p>After adding your content, move sections into the order that best supports your application.</p>
                            </span>
                        </div>
                    </div>
                    <div class="aw-rb-manager-list" data-section-manager>
                        <div class="aw-rb-empty">
                            <strong>Preparing section controls&hellip;</strong>
                            <span>Your resume sections will appear here.</span>
                        </div>
                    </div>
                </section>

                <noscript>
                    <div class="aw-rb-noscript" role="alert">
                        JavaScript is required for live preview, draft saving, and PDF generation.
                    </div>
                </noscript>
            </form>

            <footer class="aw-rb-editor-footer">
                <span>Changes save automatically</span>
                <button class="btn btn-primary" type="button" data-action="next-editor-tab">
                    <span data-next-section-label>Next: Profile</span>
                    <span aria-hidden="true">&rarr;</span>
                </button>
            </footer>
        </section>

        <aside id="rb-preview-panel"
               class="aw-panel aw-rb-preview-panel"
               data-tab-panel="preview"
               role="tabpanel"
               aria-labelledby="rb-preview-tab"
               aria-hidden="true">
            <div class="aw-rb-preview-heading" data-template-picker>
                <div class="aw-rb-preview-title">
                    <span class="aw-rb-live-dot" aria-hidden="true"></span>
                    <h2>Resume preview</h2>
                    <span data-selected-template-name>Editorial</span>
                    <small class="visually-hidden" data-selected-template-description>A refined photo-free resume with formal two-column structure.</small>
                    <span class="visually-hidden" data-template-status role="status" aria-live="polite">Editorial selected.</span>
                </div>
                <div class="aw-rb-preview-actions">
                    <button class="aw-rb-preview-size-button" type="button" data-action="open-template-picker" aria-controls="rb-template-gallery">
                        Change template
                    </button>
                    <button class="aw-rb-preview-size-button" type="button" data-action="toggle-preview-size" aria-expanded="false" aria-controls="rb-preview-panel">
                        <span data-preview-size-label>Full screen</span>
                    </button>
                </div>
            </div>

            <div class="aw-rb-preview-shell" data-preview-shell>
                <iframe class="aw-rb-preview-frame"
                        data-resume-preview
                        title="Resume PDF preview"
                        aria-describedby="rb-preview-help"></iframe>
                <div class="aw-rb-preview-state" data-preview-state role="status" aria-live="polite" aria-atomic="true" aria-busy="true">
                    <span class="aw-rb-preview-spinner" aria-hidden="true"></span>
                    <span data-preview-state-text>
                        <strong>Preparing your preview…</strong>
                        <small>ApplyWise is building a text-based PDF.</small>
                    </span>
                </div>
            </div>

            <p id="rb-preview-help" class="aw-rb-preview-help">
                This is the exact PDF you will download.
            </p>
        </aside>
    </div>

    <button class="aw-rb-preview-backdrop" type="button" data-preview-backdrop data-action="toggle-preview-size" aria-label="Close expanded preview" hidden></button>

    <dialog class="aw-rb-clear-dialog" data-clear-dialog aria-labelledby="rb-clear-title" aria-describedby="rb-clear-description">
        <form method="dialog" class="aw-rb-dialog-card">
            <span class="aw-rb-dialog-icon" aria-hidden="true">!</span>
            <div>
                <span class="aw-kicker aw-kicker-amber">Clear local draft</span>
                <h2 id="rb-clear-title">Start over with a blank resume?</h2>
                <p id="rb-clear-description">This removes every field and section from this browser. This action cannot be undone.</p>
            </div>
            <div class="aw-rb-dialog-actions">
                <button class="btn btn-secondary-soft" type="button" data-action="cancel-clear" autofocus>Keep Editing</button>
                <button class="btn aw-rb-danger-button" type="button" data-action="confirm-clear">Clear Resume</button>
            </div>
        </form>
    </dialog>
</div>

@section Scripts {
    <script src="~/lib/pdfmake/pdfmake.min.js" asp-append-version="true"></script>
    <script src="~/lib/pdfmake/vfs_fonts.js" asp-append-version="true"></script>
    <script src="~/lib/pdfmake/poppins_vfs.js" asp-append-version="true"></script>
    <script src="~/lib/pdfmake/libre_baskerville_vfs.js" asp-append-version="true"></script>
    <script src="~/js/resume-template-renderers.js" asp-append-version="true"></script>
    <script src="~/js/resume-builder.js" asp-append-version="true"></script>
}
