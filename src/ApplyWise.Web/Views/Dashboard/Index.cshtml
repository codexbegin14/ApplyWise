@model ApplyWise.Web.ViewModels.Dashboard.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }
<div class="page-heading"><div><p class="eyebrow">@Model.CurrentTime.ToString("dddd, MMMM d")</p><h2>What needs attention</h2><p>Your upcoming interviews, reminders, and application deadlines.</p></div></div>

<section class="metric-grid">
    <article class="metric-card"><span>Total Applications</span><strong>@Model.TotalApplications</strong><small><a asp-controller="JobApplications" asp-action="Index">View tracker</a></small></article>
    <article class="metric-card"><span>Interviews</span><strong>@Model.TotalInterviewCount</strong><small>@Model.UpcomingInterviewCount upcoming</small></article>
    <article class="metric-card"><span>Average Match Score</span><strong>@Model.AverageMatchScore.ToString("0.#")%</strong><small><a asp-controller="Analytics" asp-action="ResumePerformance">Resume performance</a></small></article>
    <article class="metric-card"><span>Pending Follow-ups</span><strong>@Model.PendingReminderCount</strong><small class="@(Model.OverdueReminderCount > 0 ? "danger-text" : null)">@Model.OverdueReminderCount overdue</small></article>
</section>

<div class="action-dashboard-grid">
    <section class="panel today-actions-panel"><div class="panel-header"><div><h3>Today's Actions</h3><p>Everything due before the day ends</p></div><span class="today-count">@Model.TodayActionCount</span></div>
        @if (Model.TodayActions.Count == 0) { <div class="compact-empty"><strong>Nothing due today</strong><span>Your upcoming work will appear here.</span></div> }
        else { <div class="action-item-list">@foreach (var item in Model.TodayActions) { <a class="action-item" asp-controller="@item.Controller" asp-action="@item.Action" asp-route-id="@item.Id"><span class="action-kind">@item.Kind</span><span><strong>@item.Title</strong><small>@item.Context</small></span><time>@item.SortAt.ToLocalTime().ToString("h:mm tt")</time></a> }</div> }
    </section>

    <section class="panel"><div class="panel-header"><div><h3>Upcoming Interviews</h3><p>Your next scheduled conversations</p></div><a asp-controller="Interviews" asp-action="Index">View all</a></div>
        @if (Model.UpcomingInterviews.Count == 0) { <div class="compact-empty"><strong>No interviews scheduled</strong><a asp-controller="Interviews" asp-action="Create">Add an interview</a></div> }
        else { <div class="dashboard-schedule-list">@foreach (var interview in Model.UpcomingInterviews) { <a asp-controller="Interviews" asp-action="Details" asp-route-id="@interview.Id"><span class="date-tile"><strong>@interview.ScheduledAt.ToLocalTime().Day</strong><small>@interview.ScheduledAt.ToLocalTime().ToString("MMM").ToUpperInvariant()</small></span><span><strong>@interview.InterviewType.GetDisplayName()</strong><small>@interview.JobTitle at @interview.CompanyName · @interview.ScheduledAt.ToLocalTime().ToString("h:mm tt")</small></span></a> }</div> }
    </section>

    <section class="panel"><div class="panel-header"><div><h3>Pending Reminders</h3><p>Your next follow-ups and tasks</p></div><a asp-controller="Reminders" asp-action="Index">View all</a></div>
        @if (Model.PendingReminders.Count == 0) { <div class="compact-empty"><strong>No pending reminders</strong><a asp-controller="Reminders" asp-action="Create">Add a reminder</a></div> }
        else { <div class="dashboard-task-list">@foreach (var reminder in Model.PendingReminders) { <a asp-controller="Reminders" asp-action="Index"><span class="task-status-dot @(reminder.IsOverdue ? "overdue" : null)"></span><span><strong>@reminder.Title</strong><small>@(reminder.CompanyName ?? "Standalone") · @reminder.DueAt.ToLocalTime().ToString("MMM d, h:mm tt")</small></span></a> }</div> }
    </section>

    <section class="panel"><div class="panel-header"><div><h3>Application Deadlines</h3><p>Upcoming closing dates</p></div><a asp-controller="JobApplications" asp-action="Index" asp-route-sortBy="deadline">View applications</a></div>
        @if (Model.UpcomingDeadlines.Count == 0) { <div class="compact-empty"><strong>No upcoming deadlines</strong><span>Deadlines saved on applications appear here.</span></div> }
        else { <div class="dashboard-deadline-list">@foreach (var deadline in Model.UpcomingDeadlines) { <a asp-controller="JobApplications" asp-action="Details" asp-route-id="@deadline.Id"><span><strong>@deadline.JobTitle</strong><small>@deadline.CompanyName</small></span><time>@deadline.Deadline.ToString("MMM d")</time></a> }</div> }
    </section>
</div>

<div class="dashboard-insights-grid">
    <section class="panel"><div class="panel-header"><div><h3>Top Skill Gaps</h3><p>Recurring missing requirements</p></div><a asp-controller="Analytics" asp-action="SkillGaps">View trends</a></div>@if (Model.TopSkillGaps.Count == 0) { <div class="compact-empty"><strong>No analysis trends yet</strong><a asp-controller="ResumeAnalyzer" asp-action="Index">Analyze a resume</a></div> } else { <div class="insight-list">@foreach (var skill in Model.TopSkillGaps) { <div><span><strong>@skill.SkillName</strong><small>@skill.RelatedJobCount related jobs</small></span><span class="priority @(skill.Priority == "High" ? "priority-high" : skill.Priority == "Medium" ? "priority-medium" : "priority-low")">@skill.Priority</span><b>@skill.MissingCount×</b></div> }</div> }</section>
    <section class="panel"><div class="panel-header"><div><h3>Recent Applications</h3><p>Latest tracker activity</p></div><a asp-controller="JobApplications" asp-action="Index">View all</a></div>@if (Model.RecentApplications.Count == 0) { <div class="compact-empty"><strong>No applications yet</strong></div> } else { <div class="recent-insight-list">@foreach (var application in Model.RecentApplications) { <a asp-controller="JobApplications" asp-action="Details" asp-route-id="@application.Id"><span><strong>@application.JobTitle</strong><small>@application.CompanyName</small></span><span class="badge @StatusClass(application.Status)">@application.Status.GetDisplayName()</span></a> }</div> }</section>
    <section class="panel"><div class="panel-header"><div><h3>Recent Analysis Scores</h3><p>Latest resume comparisons</p></div><a asp-controller="ResumeAnalyzer" asp-action="History">View history</a></div>@if (Model.RecentAnalyses.Count == 0) { <div class="compact-empty"><strong>No analyses yet</strong></div> } else { <div class="recent-insight-list">@foreach (var analysis in Model.RecentAnalyses) { <a asp-controller="ResumeAnalyzer" asp-action="Details" asp-route-id="@analysis.Id"><span><strong>@analysis.JobTitle</strong><small>@analysis.ResumeVersionName · @analysis.CompanyName</small></span><b>@analysis.MatchScore%</b></a> }</div> }</section>
</div>

@functions {
    private static string StatusClass(ApplicationStatus status) => status switch { ApplicationStatus.Saved or ApplicationStatus.Withdrawn => "status-saved", ApplicationStatus.Applied => "status-applied", ApplicationStatus.Shortlisted or ApplicationStatus.Offer => "status-offer", ApplicationStatus.Interview => "status-shortlisted", ApplicationStatus.TechnicalTest => "status-interview", ApplicationStatus.Rejected => "status-rejected", _ => "status-saved" };
}
