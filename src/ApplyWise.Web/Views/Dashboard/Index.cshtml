@model ApplyWise.Web.ViewModels.Dashboard.DashboardViewModel
@using ApplyWise.Web.Models
@{
    ViewData["Title"] = "Dashboard";
    var focus = Model.TodayActions.FirstOrDefault();
    var pipelineStages = Enum.GetValues<ApplicationStatus>();
    var selectedPipelineStatus = ViewData["SelectedPipelineStatus"] is ApplicationStatus status
        ? status
        : ApplicationStatus.Applied;
    var selectedApplications = Model.PipelineApplications
        .Where(application => application.Status == selectedPipelineStatus)
        .ToArray();
}
<div class="aw-page aw-dashboard-v3 aw-fade-in" data-display-name="@Model.DisplayName">
    <header class="aw-dashboard-greeting">
        <div>
            <span class="aw-dashboard-greeting-line" data-local-greeting>Good afternoon, @Model.DisplayName</span>
            <p>@Model.CurrentTime.ToLocalTime().ToString("dddd, MMMM d, yyyy")</p>
        </div>
    </header>

    <section class="aw-dashboard-focus aw-slide-up" aria-labelledby="focus-title">
        <div>
            <span class="aw-kicker">Next step</span>
            <h1 id="focus-title">@(focus is null ? "Keep your workspace moving" : focus.Title)</h1>
            <p>@(focus is null ? "Keep your workspace ready with one small, useful move." : focus.Context)</p>
        </div>
        <div class="aw-focus-action">
            @if (focus is null)
            {
                <a class="btn btn-primary" asp-controller="JobApplications" asp-action="Create">Add application</a>
            }
            else
            {
                <a class="btn btn-primary" asp-controller="@focus.Controller" asp-action="@focus.Action" asp-route-id="@focus.Id">Open next step</a>
            }
        </div>
    </section>

    <section class="aw-panel aw-pipeline-panel aw-slide-up" aria-labelledby="pipeline-title">
        <div class="aw-section-heading aw-section-heading-inline">
            <div>
                <span class="aw-kicker">Your job search at a glance</span>
                <h2 id="pipeline-title">Application pipeline</h2>
                <p>Every role stays in its current stage. Update an application to move it through the pipeline.</p>
            </div>
            <a asp-controller="JobApplications" asp-action="Index">Open application workspace</a>
        </div>
        <nav class="aw-status-counts" aria-label="Applications by status">
            @foreach (var stage in pipelineStages)
            {
                var count = Model.PipelineApplications.Count(application => application.Status == stage);
                <a class="aw-status-count @(stage == selectedPipelineStatus ? "is-selected" : string.Empty)"
                   aria-current="@(stage == selectedPipelineStatus ? "page" : null)"
                   asp-action="Index" asp-route-tab="@stage">
                    <span>@stage.GetDisplayName()</span><strong>@count</strong>
                </a>
            }
        </nav>

        <section class="aw-status-list" aria-label="@selectedPipelineStatus.GetDisplayName() applications">
            <div class="aw-status-heading">
                <div><span class="aw-kicker">@selectedPipelineStatus.GetDisplayName()</span><h3>@selectedApplications.Length job@(selectedApplications.Length == 1 ? string.Empty : "s")</h3></div>
            </div>
            @if (selectedApplications.Length == 0)
            {
                <div class="aw-pipeline-empty">No roles in this status yet.</div>
            }
            else
            {
                <div class="aw-status-list-items">
                    @foreach (var application in selectedApplications)
                    {
                        <article class="aw-status-job">
                            <span class="aw-company-avatar">@Initial(application.CompanyName)</span>
                            <div><strong>@application.JobTitle</strong><small>@application.CompanyName</small></div>
                            <form asp-controller="JobApplications" asp-action="UpdateStatus" asp-route-id="@application.Id" method="post" class="aw-status-update-form">
                                <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Dashboard", new { tab = selectedPipelineStatus })" />
                                <select name="status" class="form-select" aria-label="Update status for @application.JobTitle at @application.CompanyName">
                                    @foreach (var option in pipelineStages)
                                    {
                                        if (option == application.Status)
                                        {
                                            <option value="@option" selected>@option.GetDisplayName()</option>
                                        }
                                        else
                                        {
                                            <option value="@option">@option.GetDisplayName()</option>
                                        }
                                    }
                                </select>
                                <button class="btn btn-secondary-soft" type="submit">Update</button>
                            </form>
                        </article>
                    }
                </div>
            }
        </section>
    </section>

</div>
@functions
{
    private static string Initial(string value) => string.IsNullOrWhiteSpace(value) ? "?" : value[..1].ToUpperInvariant();
}
