@model ApplyWise.Web.ViewModels.JobApplications.JobApplicationDetailsViewModel
@{
    ViewData["Title"] = "Application Details";
}

<div class="page-heading application-details-heading">
    <div>
        <a class="back-link" asp-action="Index">Back to applications</a>
        <div class="title-with-badge"><h2>@Model.JobTitle</h2><span class="badge @StatusClass(Model.Status)">@Model.Status.GetDisplayName()</span></div>
        <p>@Model.CompanyName</p>
    </div>
    <div class="form-actions"><a class="btn btn-outline-secondary" asp-controller="Interviews" asp-action="Create" asp-route-jobApplicationId="@Model.Id">Add Interview</a><a class="btn btn-outline-secondary" asp-controller="Reminders" asp-action="Create" asp-route-jobApplicationId="@Model.Id">Add Reminder</a><a class="btn btn-outline-secondary" asp-controller="BestResumePicker" asp-action="Index" asp-route-jobApplicationId="@Model.Id">Find Best Resume</a><a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit Application</a><a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a></div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert app-alert" role="status">@successMessage</div>
}

<section class="panel application-overview">
    <div class="details-grid application-details-grid">
        <div><dt>Source</dt><dd>@Model.Source.GetDisplayName()</dd></div>
        <div><dt>Resume used</dt><dd><span class="resume-memory">@(Model.ResumeVersionName ?? "Not selected")</span></dd></div>
        <div><dt>Applied date</dt><dd>@FormatDate(Model.AppliedDate)</dd></div>
        <div><dt>Deadline</dt><dd>@FormatDate(Model.Deadline)</dd></div>
        <div><dt>Location</dt><dd>@(Model.JobLocation ?? "Not specified")</dd></div>
        <div><dt>Job type</dt><dd>@(Model.JobType?.GetDisplayName() ?? "Not specified")</dd></div>
        <div><dt>Salary range</dt><dd>@(Model.SalaryRange ?? "Not specified")</dd></div>
        <div><dt>Job post</dt><dd>@if (Model.JobUrl is not null) { <a href="@Model.JobUrl" target="_blank" rel="noopener noreferrer">Open original listing</a> } else { <span>Not added</span> }</dd></div>
    </div>
</section>

<div class="application-detail-sections">
    <section class="panel content-panel"><h3>Job description</h3><p>@(string.IsNullOrWhiteSpace(Model.JobDescription) ? "No job description added." : Model.JobDescription)</p></section>
    <section class="panel content-panel"><h3>Notes</h3><p>@(string.IsNullOrWhiteSpace(Model.Notes) ? "No notes added." : Model.Notes)</p></section>
</div>

<section class="panel job-scam-section">
    <div class="panel-header"><div><h3>Job Post Review</h3><p>Check this listing for potential red flags and missing information.</p></div><a asp-controller="JobScamChecks" asp-action="History">Check history</a></div>
    @if (Model.LatestScamCheck is null)
    {
        <div class="scam-empty"><span class="scam-shield">?</span><div><strong>No scam check yet</strong><p>Run a rule-based check to review this job post for potential red flags.</p></div><form asp-controller="JobScamChecks" asp-action="Analyze" method="post"><input type="hidden" name="JobApplicationId" value="@Model.Id" /><button class="btn btn-primary" type="submit">Run Scam Check</button></form></div>
    }
    else
    {
        <div class="latest-scam-result"><div class="scam-risk-summary"><span class="badge @RiskBadge(Model.LatestScamCheck.RiskLevel)">@Model.LatestScamCheck.RiskLevel.GetDisplayName()</span><strong>@Model.LatestScamCheck.RiskScore/100 risk</strong><span>@Model.LatestScamCheck.QualityScore/100 quality</span></div><p>@Model.LatestScamCheck.Recommendation</p><div class="analysis-result-actions"><a asp-controller="JobScamChecks" asp-action="Details" asp-route-id="@Model.LatestScamCheck.Id">View full check</a><form asp-controller="JobScamChecks" asp-action="Analyze" method="post"><input type="hidden" name="JobApplicationId" value="@Model.Id" /><button class="btn btn-link" type="submit">Run again</button></form></div></div>
    }
</section>

<p class="record-timestamps">Created @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt") · Updated @Model.UpdatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt")</p>

@functions {
    private static string FormatDate(DateOnly? date) => date?.ToString("MMM d, yyyy") ?? "Not specified";
    private static string StatusClass(ApplicationStatus status) => status switch
    {
        ApplicationStatus.Saved or ApplicationStatus.Withdrawn => "status-saved",
        ApplicationStatus.Applied => "status-applied",
        ApplicationStatus.Shortlisted or ApplicationStatus.Offer => "status-offer",
        ApplicationStatus.Interview => "status-shortlisted",
        ApplicationStatus.TechnicalTest => "status-interview",
        ApplicationStatus.Rejected => "status-rejected",
        _ => "status-saved"
    };
    private static string RiskBadge(JobRiskLevel level) => level switch { JobRiskLevel.High => "status-rejected", JobRiskLevel.Medium => "status-interview", _ => "status-offer" };
}
