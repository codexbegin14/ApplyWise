@model ApplyWise.Web.ViewModels.JobApplications.JobApplicationFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

<section class="panel application-form-section">
    <div class="form-section-heading"><span>1</span><div><h3>Role details</h3><p>Basic information about the opportunity.</p></div></div>
    <div class="form-grid">
        <div><label asp-for="CompanyName" class="form-label"></label><input asp-for="CompanyName" class="form-control" placeholder="Company name" /><span asp-validation-for="CompanyName" class="field-validation-error"></span></div>
        <div><label asp-for="JobTitle" class="form-label"></label><input asp-for="JobTitle" class="form-control" placeholder="Role title" /><span asp-validation-for="JobTitle" class="field-validation-error"></span></div>
        <div><label asp-for="JobLocation" class="form-label"></label><input asp-for="JobLocation" class="form-control" placeholder="City, country or remote" /><span asp-validation-for="JobLocation" class="field-validation-error"></span></div>
        <div><label asp-for="JobType" class="form-label"></label><select asp-for="JobType" asp-items="Html.GetEnumSelectList<JobType>()" class="form-select"><option value="">Not specified</option></select><span asp-validation-for="JobType" class="field-validation-error"></span></div>
        <div><label asp-for="SalaryRange" class="form-label"></label><input asp-for="SalaryRange" class="form-control" placeholder="e.g. PKR 150k - 200k" /><span asp-validation-for="SalaryRange" class="field-validation-error"></span></div>
    </div>
</section>

<section class="panel application-form-section">
    <div class="form-section-heading"><span>2</span><div><h3>Application details</h3><p>Remember where, when, and how you applied.</p></div></div>
    <div class="form-grid">
        <div><label asp-for="Source" class="form-label"></label><select asp-for="Source" asp-items="Html.GetEnumSelectList<JobSource>()" class="form-select"></select><span asp-validation-for="Source" class="field-validation-error"></span></div>
        <div><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Html.GetEnumSelectList<ApplicationStatus>()" class="form-select"></select><span asp-validation-for="Status" class="field-validation-error"></span></div>
        <div><label asp-for="ResumeId" class="form-label"></label><select asp-for="ResumeId" asp-items="Model.AvailableResumes" class="form-select"><option value="">No resume selected</option></select><span asp-validation-for="ResumeId" class="field-validation-error"></span></div>
        <div><label asp-for="AppliedDate" class="form-label"></label><input asp-for="AppliedDate" class="form-control" /><div class="form-hint">Recommended when the status is Applied.</div><span asp-validation-for="AppliedDate" class="field-validation-error"></span></div>
        <div><label asp-for="Deadline" class="form-label"></label><input asp-for="Deadline" class="form-control" /><span asp-validation-for="Deadline" class="field-validation-error"></span></div>
        <div class="form-grid-wide"><label asp-for="JobUrl" class="form-label"></label><input asp-for="JobUrl" class="form-control" placeholder="https://..." /><span asp-validation-for="JobUrl" class="field-validation-error"></span></div>
    </div>
</section>

<section class="panel application-form-section">
    <div class="form-section-heading"><span>3</span><div><h3>Description and notes</h3><p>Keep useful context with the application.</p></div></div>
    <div class="mb-4"><label asp-for="JobDescription" class="form-label"></label><textarea asp-for="JobDescription" class="form-control" rows="8" placeholder="Paste or summarize the job description"></textarea><span asp-validation-for="JobDescription" class="field-validation-error"></span></div>
    <div><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="4" placeholder="Contacts, follow-up details, or preparation notes"></textarea><span asp-validation-for="Notes" class="field-validation-error"></span></div>
</section>
