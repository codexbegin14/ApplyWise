@model ApplyWise.Web.ViewModels.JobScamChecks.JobScamCheckDetailsViewModel
@{ ViewData["Title"] = "Scam Check Details"; }
<div class="page-heading"><div><a class="back-link" asp-controller="JobApplications" asp-action="Details" asp-route-id="@Model.JobApplicationId">Back to job application</a><h1>Job Post Review</h1><p>@Model.JobTitle at @Model.CompanyName</p></div><a class="btn btn-outline-secondary" asp-action="History">Check History</a></div>
<section class="scam-score-grid"><article class="panel scam-score-card"><span>Potential risk</span><div class="scam-score @RiskClass(Model.RiskLevel)"><strong>@Model.RiskScore</strong><small>/100</small></div><span class="badge @RiskBadge(Model.RiskLevel)">@Model.RiskLevel.GetDisplayName()</span></article><article class="panel scam-score-card"><span>Description quality</span><div class="scam-score @QualityClass(Model.QualityScore)"><strong>@Model.QualityScore</strong><small>/100</small></div><span>@QualityLabel(Model.QualityScore)</span></article><article class="panel scam-recommendation"><span class="method-label">Recommendation</span><p>@Model.Recommendation</p><small>Rule-based review checked @Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt"). This is not a legal or fraud determination.</small></article></section>
<div class="scam-detail-grid"><section class="panel"><div class="panel-header"><div><h3>Potential red flags</h3><p>Signals that may require additional verification</p></div><span class="keyword-count missing-count">@Model.RedFlags.Count</span></div>@if (Model.RedFlags.Count == 0) { <p class="analysis-empty-copy">No common rule-based red flags were detected.</p> } else { <ul class="review-list red-flag-list">@foreach (var flag in Model.RedFlags) { <li>@flag</li> }</ul> }</section><section class="panel"><div class="panel-header"><div><h3>Missing information</h3><p>Details that would make the job post more complete</p></div><span class="keyword-count">@Model.MissingInformation.Count</span></div>@if (Model.MissingInformation.Count == 0) { <p class="analysis-empty-copy">The post covers the main quality checks.</p> } else { <ul class="review-list">@foreach (var item in Model.MissingInformation) { <li>@item</li> }</ul> }</section></div>
@functions {
    private static string RiskClass(JobRiskLevel level) => level switch { JobRiskLevel.High => "score-low", JobRiskLevel.Medium => "score-fair", _ => "score-strong" };
    private static string RiskBadge(JobRiskLevel level) => level switch { JobRiskLevel.High => "status-rejected", JobRiskLevel.Medium => "status-interview", _ => "status-offer" };
    private static string QualityClass(int score) => score >= 75 ? "score-strong" : score >= 50 ? "score-fair" : "score-low";
    private static string QualityLabel(int score) => score >= 75 ? "High quality" : score >= 50 ? "Medium quality" : "Low quality";
}
