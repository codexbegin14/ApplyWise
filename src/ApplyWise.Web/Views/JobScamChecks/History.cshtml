@model ApplyWise.Web.ViewModels.JobScamChecks.JobScamCheckHistoryViewModel
@{ ViewData["Title"] = "Scam Check History"; }
<div class="page-heading"><div><h2>Scam Check History</h2><p>Review previous rule-based job post checks.</p></div><a class="btn btn-outline-secondary" asp-controller="JobApplications" asp-action="Index">Applications</a></div>
@if (Model.Checks.Count == 0) { <section class="panel empty-state"><span class="empty-icon">!</span><h3>No scam checks yet</h3><p>Run a scam check from a job application to review potential red flags.</p><a class="btn btn-primary" asp-controller="JobApplications" asp-action="Index">View Applications</a></section> }
else { <section class="panel analysis-history-panel"><div class="resume-list-header"><span>@Model.Checks.Count saved check@(Model.Checks.Count == 1 ? string.Empty : "s")</span><span>Private to your account</span></div><div class="table-responsive"><table class="table app-table"><thead><tr><th>Date</th><th>Job</th><th>Risk</th><th>Quality</th><th><span class="visually-hidden">Actions</span></th></tr></thead><tbody>@foreach (var check in Model.Checks) { <tr><td>@check.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td><td><div class="application-role"><strong>@check.JobTitle</strong><span>@check.CompanyName</span></div></td><td><span class="badge @RiskBadge(check.RiskLevel)">@check.RiskScore · @check.RiskLevel.GetDisplayName()</span></td><td>@check.QualityScore%</td><td class="text-end"><a asp-action="Details" asp-route-id="@check.Id">View</a></td></tr> }</tbody></table></div></section> }
@functions { private static string RiskBadge(JobRiskLevel level) => level switch { JobRiskLevel.High => "status-rejected", JobRiskLevel.Medium => "status-interview", _ => "status-offer" }; }
