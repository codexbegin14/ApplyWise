@model ApplyWise.Web.ViewModels.Resumes.ResumeDetailsViewModel
@{
    ViewData["Title"] = "Delete Resume";
}

<div class="page-heading"><div><h1>Delete Resume</h1><p>Review this resume before removing it.</p></div></div>

<section class="panel confirmation-panel">
    <span class="danger-mark" aria-hidden="true">!</span>
    <h3>Delete @Model.VersionName?</h3>
    <p>This permanently removes <strong>@Model.OriginalFileName</strong> and its saved metadata. This action cannot be undone.</p>
    @if (Model.IsDefault)
    {
        <div class="alert alert-warning">This is currently your default resume.</div>
    }
    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="form-actions">
        <button class="btn btn-danger" type="submit">Delete Resume</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </form>
</section>
