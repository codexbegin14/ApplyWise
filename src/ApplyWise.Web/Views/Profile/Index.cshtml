@model ApplyWise.Web.ViewModels.Profile.ProfileEditViewModel
@using ApplyWise.Web.Models
@{ ViewData["Title"] = "Profile"; }
<div class="aw-page"><header class="aw-page-heading"><div><span class="aw-kicker">Your private profile</span><h1>Make your next match more useful</h1><p>Profile details stay private and help ApplyWise tailor opportunities and Wiso answers.</p></div></header><section class="aw-panel aw-profile-panel"><div class="aw-profile-avatar"><img src="@(Url.Action("Avatar", "Profile") ?? "")" alt="Your profile avatar" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" /><span> AW </span><form asp-action="Avatar" method="post" enctype="multipart/form-data"><input type="file" name="file" accept="image/png,image/jpeg,image/webp" /><button class="btn btn-secondary-soft btn-sm" type="submit">Update avatar</button></form></div><form method="post" asp-action="Save"><div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div><div class="form-grid"><div><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" /></div><div><label asp-for="CareerStage" class="form-label"></label><select asp-for="CareerStage" asp-items="Html.GetEnumSelectList<CareerStage>()" class="form-select"><option value="">Choose one</option></select></div><div><label asp-for="Institution" class="form-label"></label><input asp-for="Institution" class="form-control" /></div><div><label asp-for="DegreeProgram" class="form-label"></label><input asp-for="DegreeProgram" class="form-control" /></div><div><label asp-for="FieldOfStudy" class="form-label"></label><input asp-for="FieldOfStudy" class="form-control" /></div><div><label asp-for="GraduationYear" class="form-label"></label><input asp-for="GraduationYear" class="form-control" /></div><div><label asp-for="CurrentSemester" class="form-label"></label><input asp-for="CurrentSemester" class="form-control" /></div><div><label asp-for="PreferredLocations" class="form-label"></label><input asp-for="PreferredLocations" class="form-control" placeholder="Lahore, Islamabad, Remote" /></div><div class="form-grid-wide"><label asp-for="OpportunityInterests" class="form-label"></label><input asp-for="OpportunityInterests" class="form-control" placeholder="Internships, data, design" /></div><div class="form-grid-wide"><label asp-for="Skills" class="form-label"></label><textarea asp-for="Skills" class="form-control" rows="3" placeholder="Python, research, Figma"></textarea></div><div class="form-grid-wide"><label asp-for="CareerInterests" class="form-label"></label><textarea asp-for="CareerInterests" class="form-control" rows="3"></textarea></div><div class="form-grid-wide"><label asp-for="AcademicHighlights" class="form-label"></label><textarea asp-for="AcademicHighlights" class="form-control" rows="3"></textarea></div></div><button class="btn btn-primary" type="submit">Save profile</button></form></section></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
