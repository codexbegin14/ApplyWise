@page
@{
    ViewData["Title"] = "Check your email";
    ViewData["MetaDescription"] = "Check your email for your ApplyWise password reset link.";
}

<div class="aw-auth-status-shell aw-fade-in">
    <section class="aw-auth-status-card aw-slide-up" aria-labelledby="reset-sent-title">
        <span class="aw-auth-kicker">Reset link requested</span>
        <span class="aw-auth-status-icon aw-auth-status-icon-success" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 6h16v12H4zM4 7l8 6 8-6" /><path d="m9 13 2 2 4-4" /></svg>
        </span>
        <h1 id="reset-sent-title">Check your email</h1>
        <p>If an ApplyWise account exists for that address, a password reset link is on its way.</p>

        <div class="aw-auth-status-callout aw-auth-status-callout-success" role="status">
            The link may take a minute to arrive. Check your spam folder if you do not see it.
        </div>
        <div class="aw-auth-status-actions">
            <a class="btn btn-primary" asp-page="./Login">Back to log in</a>
            <a class="btn btn-secondary-soft" asp-page="./ForgotPassword">Try another email</a>
        </div>
    </section>

    <aside class="aw-auth-status-visual is-success" aria-label="Wiso password reset reminder">
        <div>
            <span class="aw-auth-kicker">What happens next</span>
            <h2>Open the secure link</h2>
            <p>Choose a new password, then return to ApplyWise and keep moving.</p>
        </div>
        <img src="~/images/wiso.png" alt="Wiso, your ApplyWise career assistant" />
        <span class="aw-auth-status-bubble">Almost there!</span>
    </aside>
</div>
