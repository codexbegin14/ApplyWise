@page
@model ApplyWise.Web.Areas.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = Model.Succeeded ? "Email confirmed" : "Confirmation link problem";
}

<div class="aw-auth-status-shell aw-fade-in d-block"
     @if (Model.Succeeded) { <text>data-confirm-redirect="@Model.LoginUrl" data-confirm-redirect-seconds="5"</text> }>
    <section class="aw-auth-status-card aw-slide-up col-lg-8 mx-auto" aria-labelledby="email-confirmation-title">
        <span class="aw-auth-kicker"><svg class="ui-icon"><use href="#i-spark" /></svg>Email confirmation</span>
        <span class="aw-auth-status-icon @(Model.Succeeded ? "aw-auth-status-icon-success" : "aw-auth-status-icon-error")" aria-hidden="true">
            @if (Model.Succeeded)
            {
                <svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6" /></svg>
            }
            else
            {
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 7v6M12 17h.01" /></svg>
            }
        </span>
        <h1 id="email-confirmation-title">@(Model.Succeeded ? "Your email is confirmed" : "We could not confirm this link")</h1>
        <p>@Model.StatusMessage</p>

        @if (Model.Succeeded)
        {
            <div class="aw-auth-status-callout aw-auth-status-callout-success" role="status">
                Taking you to login in <strong data-confirm-redirect-countdown>5</strong> seconds. You will still enter your password to sign in.
            </div>
            <div class="aw-auth-status-actions">
                <a class="btn btn-primary" href="@Model.LoginUrl">Continue to login now</a>
            </div>
        }
        else
        {
            <div class="aw-auth-status-callout aw-auth-status-callout-error">
                Confirmation links can expire or become invalid after they have been used.
            </div>
            <div class="aw-auth-status-actions">
                <a class="btn btn-primary" asp-page="./ResendEmailConfirmation">Send a new link</a>
                <a class="btn btn-secondary-soft" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Back to login</a>
            </div>
        }
    </section>

</div>
