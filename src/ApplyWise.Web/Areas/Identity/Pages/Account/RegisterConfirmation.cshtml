@page
@model ApplyWise.Web.Areas.Identity.Pages.Account.RegisterConfirmationModel
@{
    ViewData["Title"] = "Check your email";
}

<div class="aw-auth-status-shell aw-fade-in d-block">
    <section class="aw-auth-status-card aw-slide-up col-lg-8 mx-auto" aria-labelledby="registration-confirmation-title">
        <span class="aw-auth-kicker"><svg class="ui-icon"><use href="#i-spark" /></svg>One quick step</span>
        <span class="aw-auth-status-icon aw-auth-status-icon-pending" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M3 6h18v12H3z" /><path d="m3 7 9 6 9-6" /></svg>
        </span>
        <h1 id="registration-confirmation-title">Check your inbox</h1>
        <p>We sent a confirmation link to <strong>@Model.Email</strong>.</p>

        <div class="aw-auth-status-callout">
            Open the ApplyWise email and choose <strong>Confirm email</strong>. You can then return and log in securely.
        </div>

        <div class="aw-auth-status-actions">
            <a class="btn btn-primary" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Go to login</a>
            <a class="btn btn-secondary-soft" asp-page="./ResendEmailConfirmation">Resend confirmation</a>
        </div>
        <p class="aw-auth-status-hint">No message yet? Check your spam folder and make sure the email address is correct.</p>
    </section>

</div>
