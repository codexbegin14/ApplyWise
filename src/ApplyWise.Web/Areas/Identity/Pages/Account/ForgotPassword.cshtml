@page
@model ApplyWise.Web.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Reset password";
    ViewData["MetaDescription"] = "Request a secure ApplyWise password reset link.";
}

<div class="aw-auth-shell aw-auth-shell-recovery aw-fade-in">
    <section class="aw-login-card aw-recovery-card aw-slide-up" aria-labelledby="forgot-password-title">
        <header class="aw-login-heading">
            <span class="aw-auth-kicker">Account recovery</span>
            <h1 id="forgot-password-title">Reset your password</h1>
            <p>Enter the email connected to your account and we’ll send you a secure reset link.</p>
        </header>

        <form method="post" class="aw-login-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary aw-login-alert" role="alert"></div>

            <label class="aw-login-field" asp-for="Input.Email">
                <span>Email address</span>
                <span class="aw-login-input">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4zM4 7l8 6 8-6" /></svg>
                    <input asp-for="Input.Email" autocomplete="email" placeholder="you@example.com" autofocus />
                </span>
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg aw-login-submit">
                Send reset link <svg class="ui-icon"><use href="#i-arrow" /></svg>
            </button>

            <a class="aw-recovery-back" asp-page="./Login">
                <span aria-hidden="true">←</span> Back to log in
            </a>
        </form>

        <footer class="aw-login-footer"><span>✓</span> For your security, reset links expire after use.</footer>
    </section>

    <aside class="aw-auth-visual aw-recovery-visual" aria-label="ApplyWise password recovery">
        <div class="aw-auth-quote">
            <span class="aw-auth-kicker">A quick reset</span>
            <blockquote>Get back to your job search without losing momentum.</blockquote>
        </div>
        <div class="aw-auth-avatar-wrap">
            <span>I’ll help you get back in!</span>
            <img src="~/images/wiso.png" alt="Wiso, your ApplyWise career assistant" />
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
