@page
@model ApplyWise.Web.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="aw-auth-shell aw-auth-shell-register aw-fade-in">
    <section class="aw-login-card aw-register-card aw-slide-up" aria-labelledby="register-title">
        <header class="aw-login-heading">
            <h1 id="register-title">Create your ApplyWise account</h1>
        </header>

        <form id="registerForm" method="post" class="aw-login-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary aw-login-alert" role="alert"></div>

            <label class="aw-login-field" asp-for="Input.FullName">
                <span>Full name</span>
                <span class="aw-login-input">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                    <input asp-for="Input.FullName" autocomplete="name" placeholder="Your full name" autofocus />
                </span>
                <span asp-validation-for="Input.FullName" class="field-validation-error"></span>
            </label>

            <div class="aw-register-demographics">
                <label class="aw-login-field" asp-for="Input.Gender">
                    <span>Gender</span>
                    <span class="aw-login-input aw-login-select">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" /></svg>
                        <select asp-for="Input.Gender">
                            <option value="">Choose gender</option>
                            <option value="Woman">Woman</option>
                            <option value="Man">Man</option>
                            <option value="NonBinary">Non-binary</option>
                            <option value="PreferNotToSay">Prefer not to say</option>
                        </select>
                    </span>
                    <span asp-validation-for="Input.Gender" class="field-validation-error"></span>
                </label>

                <label class="aw-login-field" asp-for="Input.DateOfBirth">
                    <span>Date of birth</span>
                    <span class="aw-login-input">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2" /><path d="M8 3v4M16 3v4M3 10h18" /></svg>
                        <input asp-for="Input.DateOfBirth" type="date" autocomplete="bday" max="@DateOnly.FromDateTime(DateTime.UtcNow).ToString("yyyy-MM-dd")" />
                    </span>
                    <span asp-validation-for="Input.DateOfBirth" class="field-validation-error"></span>
                </label>
            </div>

            <label class="aw-login-field" asp-for="Input.Email">
                <span>Email address</span>
                <span class="aw-login-input">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4zM4 7l8 6 8-6" /></svg>
                    <input asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
                </span>
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </label>

            <div class="aw-login-field">
                <label class="aw-login-field-label" asp-for="Input.Password">Password</label>
                <span class="aw-login-input">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="10" width="14" height="10" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" /></svg>
                    <input asp-for="Input.Password" autocomplete="new-password" placeholder="Create a secure password" aria-describedby="password-requirements" />
                    <partial name="_PasswordToggle" model='"Input_Password"' />
                </span>
                <small id="password-requirements" class="aw-password-help">Use at least 6 characters and include one number.</small>
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="aw-login-field">
                <label class="aw-login-field-label" asp-for="Input.ConfirmPassword">Confirm password</label>
                <span class="aw-login-input">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="10" width="14" height="10" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" /></svg>
                    <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="Repeat your password" />
                    <partial name="_PasswordToggle" model='"Input_ConfirmPassword"' />
                </span>
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg aw-login-submit">Create account <svg class="ui-icon"><use href="#i-arrow" /></svg></button>
            <a class="btn btn-secondary-soft aw-create-account" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Back to log in</a>
        </form>
    </section>

    <aside class="aw-auth-visual aw-auth-visual-signup" aria-label="Meet Wiso, your ApplyWise assistant">
        <div class="aw-auth-quote">
            <span class="aw-auth-kicker">Start with Wiso</span>
            <blockquote>Turn your job search into clear next steps.</blockquote>
            <p>Build resumes, check what is missing, and keep every application moving in one place.</p>
        </div>
        <div class="aw-auth-avatar-wrap">
            <span>Let's begin!</span>
            <img src="~/images/wiso.png" alt="Wiso welcoming you to ApplyWise" />
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
