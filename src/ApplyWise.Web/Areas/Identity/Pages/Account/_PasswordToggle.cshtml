@model string
@{
    var fieldName = Model.Contains("Confirm", StringComparison.Ordinal) ? "confirmation password" : "password";
}
<button class="aw-password-toggle"
        type="button"
        data-password-toggle
        aria-controls="@Model"
        aria-pressed="false"
        aria-label="Show @fieldName">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" /><circle cx="12" cy="12" r="2.5" /></svg>
    <span data-password-toggle-text>Show</span>
</button>
