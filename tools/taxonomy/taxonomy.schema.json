{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://applywise.local/schemas/skill-taxonomy-v1.json",
  "title": "ApplyWise skill taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taxonomyVersion",
    "source",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "taxonomyVersion": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "license"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "preferredLabel",
        "aliases",
        "category",
        "ambiguity"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+:[A-Za-z0-9._-]+$"
        },
        "preferredLabel": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "ambiguity": {
          "$ref": "#/$defs/ambiguity"
        }
      }
    },
    "ambiguity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiresContext",
        "aliases"
      ],
      "properties": {
        "requiresContext": {
          "type": "boolean"
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
